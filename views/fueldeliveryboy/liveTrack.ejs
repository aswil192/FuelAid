<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Tactical Tracking | FuelAid</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.tracking-node {
			background: var(--card-bg);
			border-radius: 25px;
			padding: 2.5rem;
			margin-bottom: 2rem;
			border: 1px solid #eee;
			color: var(--text-dark);
		}

		.map-viewport {
			height: 400px;
			border-radius: 20px;
			border: 1px solid #ddd;
			margin-top: 1.5rem;
			box-shadow: inset 0 2px 10px rgba(0,0,0,0.05);
		}

		.intel-badge {
			padding: 0.5rem 1.5rem;
			border-radius: 20px;
			font-size: 0.75rem;
			font-weight: 800;
			text-transform: uppercase;
			letter-spacing: 1px;
			background: #f8f9fa;
			border: 1px solid #eee;
			color: #666;
		}

		.intel-badge.active { background: var(--accent-yellow); color: #000; border-color: var(--accent-yellow); }

		.intel-label {
			font-size: 0.7rem;
			font-weight: 800;
			color: #888;
			text-transform: uppercase;
			letter-spacing: 1.5px;
			margin-bottom: 0.5rem;
		}

		@media (max-width: 991px) {
			#main-wrapper { margin-left: 0; padding: 1.5rem; }
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
	<%- include('../partials/fuelSidebar') %>

	<div id="main-wrapper">
		<%- include('../partials/alerts') %>

		<div class="mb-5">
			<h1 class="hero-title mb-0">Tactical <span>Tracking</span></h1>
			<p class="text-muted">Real-time assets and customer delivery coordinates.</p>
		</div>

		<% if (requests.length === 0) { %>
			<div class="empty-quest-state text-center py-5">
				<i class="fas fa-radar mb-4" style="font-size: 4rem; color: #333;"></i>
				<h4>Static Signal. No active missions detected.</h4>
				<p>Live tracking will initialize once a delivery objective is accepted.</p>
			</div>
		<% } else { %>
			<% requests.forEach((req, idx) => { %>
				<div class="tracking-node">
					<div class="d-flex justify-content-between align-items-center mb-4">
						<h4 class="fw-800 text-dark mb-0"><%= req.serviceCategory.toUpperCase() %> <span class="text-muted smaller fw-400">#<%= idx + 1 %></span></h4>
						<div class="d-flex gap-2">
							<span class="intel-badge active" id="status-<%= idx %>">Initializing...</span>
							<span class="intel-badge" id="eta-<%= idx %>">Calculating...</span>
						</div>
					</div>

					<div class="row g-4 mb-4">
						<div class="col-md-6">
							<div class="intel-label">Customer Intelligence</div>
							<div class="fw-700 text-dark"><%= req.customer.firstName %> <%= req.customer.lastName %></div>
							<div class="small text-muted"><%= req.customer.phone %></div>
						</div>
						<div class="col-md-6">
							<div class="intel-label">Point of Objective</div>
							<div class="fw-700 text-dark small"><%= req.address %></div>
						</div>
					</div>

					<div id="map-<%= idx %>" class="map-viewport"></div>
				</div>
			<% }) %>
		<% } %>
	</div>

	<div id="tracking-data" data-requests='<%- JSON.stringify(requests) %>'></div>

	<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
	<script src="/socket.io/socket.io.js"></script>
	<script>
		const socket = io();
		const requestData = document.getElementById('tracking-data').dataset.requests;
		const requests = JSON.parse(requestData);
		const fuelMarkers = {};

		requests.forEach((req, idx) => {
			if (!req.fueldeliveryboy) return;
			const map = L.map(`map-${idx}`).setView([req.latitude, req.longitude], 13);
			L.tileLayer('https://{s}.tile.openstreetmap.fr/hot/{z}/{x}/{y}.png', {
				attribution: '&copy; OpenStreetMap contributors'
			}).addTo(map);

			L.marker([req.latitude, req.longitude], {
				icon: L.icon({
					iconUrl: 'https://cdn-icons-png.flaticon.com/512/1946/1946433.png',
					iconSize: [30, 30],
				})
			}).addTo(map).bindPopup("Customer's Location");

			const fuelId = req.fueldeliveryboy._id;
			const fuelMarker = L.marker([req.fueldeliveryboy.latitude, req.fueldeliveryboy.longitude], {
				icon: L.icon({
					iconUrl: 'https://cdn-icons-png.flaticon.com/512/854/854878.png',
					iconSize: [30, 30],
				})
			}).addTo(map).bindPopup("Your Position");

			if (!fuelMarkers[fuelId]) fuelMarkers[fuelId] = [];
			fuelMarkers[fuelId].push({
				map, marker: fuelMarker, customerLatLng: [req.latitude, req.longitude], requestIndex: idx
			});
		});

		function haversineDistance(lat1, lon1, lat2, lon2) {
			const R = 6371;
			const toRad = angle => angle * (Math.PI / 180);
			const dLat = toRad(lat2 - lat1);
			const dLon = toRad(lon2 - lon1);
			const a = Math.sin(dLat / 2) ** 2 + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon / 2) ** 2;
			return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
		}

		function estimateArrivalTime(dist) {
			const totalMin = Math.round((dist / 40) * 60);
			const h = Math.floor(totalMin / 60);
			const m = totalMin % 60;
			return h > 0 ? `${h}h ${m}m` : `${m}m`;
		}

		socket.on('updateFuelLocation', ({ fuelId, lat, lng }) => {
			const instances = fuelMarkers[fuelId];
			if (instances) {
				instances.forEach(({ map, marker, customerLatLng, requestIndex }) => {
					const dist = haversineDistance(lat, lng, customerLatLng[0], customerLatLng[1]);
					document.getElementById(`eta-${requestIndex}`).textContent = `ETA: ${estimateArrivalTime(dist)}`;
					document.getElementById(`status-${requestIndex}`).textContent = dist < 0.1 ? "At Objective" : "On the way";
					marker.setLatLng([lat, lng]);
					map.panTo([lat, lng]);
				});
			}
		});

		// Simulation Logic
		const currentFuelId = "<%= currentUser._id %>";
		let sLat = 28.628151;
		let sLng = 77.367783;
		setInterval(() => {
			sLat += 0.0001;
			sLng += 0.0001;
			socket.emit('fuelLocationUpdate', { fuelId: currentFuelId, lat: sLat, lng: sLng });
		}, 5000);
	</script>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
	<script src="/assets/js/script.js"></script>
</body>
</html>