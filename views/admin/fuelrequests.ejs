<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Fuel Requests | RoadAid Admin</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.page-header {
			margin-bottom: 3rem;
			border-left: 5px solid var(--accent-yellow);
			padding-left: 1.5rem;
		}

		.page-header h2 {
			font-weight: 800;
			margin: 0;
			text-transform: uppercase;
			letter-spacing: 1px;
		}

		.fuel-request-grid {
			display: grid;
			grid-template-columns: 1fr;
			gap: 2.5rem;
		}

		.fuel-job-card {
			background: var(--card-bg);
			border-radius: 30px;
			overflow: hidden;
			color: var(--text-dark);
			border: 1px solid #333;
			box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
			display: grid;
			grid-template-columns: 320px 1fr;
		}

		/* Side Summary */
		.fuel-job-side {
			background: #111;
			padding: 2.5rem;
			color: #fff;
			position: relative;
		}

		.fuel-job-side::after {
			content: "\f52f";
			/* gas-pump icon */
			font-family: "Font Awesome 6 Free";
			font-weight: 900;
			position: absolute;
			bottom: -20px;
			right: -20px;
			font-size: 8rem;
			opacity: 0.05;
			color: var(--accent-yellow);
		}

		.job-index-tag {
			font-size: 0.7rem;
			font-weight: 800;
			color: var(--accent-yellow);
			letter-spacing: 2px;
			text-transform: uppercase;
			margin-bottom: 1.5rem;
			display: block;
		}

		.fuel-type-badge {
			display: inline-block;
			background: #222;
			color: #fff;
			padding: 0.5rem 1.25rem;
			border-radius: 12px;
			font-weight: 800;
			font-size: 0.8rem;
			border: 1px solid #333;
			margin-bottom: 2rem;
		}

		.delivery-destination h6 {
			font-size: 0.65rem;
			text-transform: uppercase;
			letter-spacing: 1.5px;
			color: #888;
			font-weight: 700;
			margin-bottom: 0.5rem;
		}

		.delivery-destination p {
			font-size: 0.9rem;
			font-weight: 600;
			line-height: 1.6;
			margin: 0;
			color: #eee;
		}

		/* Action Content */
		.fuel-job-main {
			padding: 2.5rem;
			display: flex;
			flex-direction: column;
		}

		.customer-card-mini {
			display: flex;
			align-items: center;
			gap: 1.5rem;
			margin-bottom: 2.5rem;
			padding-bottom: 1.5rem;
			border-bottom: 1px solid #eee;
		}

		.cust-avatar-box {
			width: 60px;
			height: 60px;
			background: #f0f0f0;
			border-radius: 20px;
			display: flex;
			align-items: center;
			justify-content: center;
			font-weight: 800;
			font-size: 1.25rem;
			color: #111;
			border: 2px solid var(--accent-yellow);
		}

		.cust-meta-v h5 {
			margin: 0;
			font-weight: 800;
			color: #111;
		}

		.cust-meta-v span {
			font-size: 0.8rem;
			color: #888;
			font-weight: 600;
		}

		.order-details-summary {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 1.5rem;
			margin-bottom: 2.5rem;
		}

		.order-detail-item label {
			display: block;
			font-size: 0.65rem;
			text-transform: uppercase;
			font-weight: 700;
			color: #999;
			margin-bottom: 0.3rem;
		}

		.order-detail-item span {
			font-weight: 800;
			color: #111;
			font-size: 1rem;
		}

		.dispatch-control-pane {
			margin-top: auto;
			background: #f8f9fa;
			border: 1px solid #eee;
			border-radius: 20px;
			padding: 1.5rem 2rem;
		}

		.pane-header {
			font-size: 0.75rem;
			font-weight: 800;
			text-transform: uppercase;
			color: #111;
			margin-bottom: 1rem;
			display: flex;
			align-items: center;
			gap: 0.75rem;
		}

		.pane-header i {
			color: var(--accent-yellow);
		}

		.dispatch-input-group {
			display: grid;
			grid-template-columns: 1fr auto;
			gap: 1rem;
		}

		.select-fleet {
			background: #fff;
			border: 2px solid #eee;
			border-radius: 12px;
			padding: 0.8rem 1.25rem;
			font-weight: 600;
			color: #333;
		}

		.select-fleet:focus {
			border-color: var(--accent-yellow);
			outline: none;
		}

		.btn-authorize-fleet {
			background: var(--accent-yellow);
			color: #000;
			border: none;
			padding: 0 2.5rem;
			border-radius: 12px;
			font-weight: 800;
			text-transform: uppercase;
			font-size: 0.8rem;
			transition: var(--transition);
		}

		.btn-authorize-fleet:hover {
			transform: scale(1.02);
			box-shadow: 0 10px 20px rgba(247, 183, 29, 0.3);
		}

		@media (max-width: 991px) {
			#main-wrapper {
				margin-left: 0;
				padding: 1.5rem;
			}

			.fuel-job-card {
				grid-template-columns: 1fr;
			}

			.fuel-job-side {
				padding: 1.5rem;
			}

			.fuel-job-main {
				padding: 1.5rem;
			}

			.order-details-summary {
				grid-template-columns: 1fr 1fr;
			}
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
		<%- include('../partials/adminSidebar', { title: 'Fuel Requests' }) %>

			<div id="main-wrapper">
				<div class="page-header">
					<h2>Logistics <span>Overview</span></h2>
					<p class="text-muted mb-0">Manage incoming fuel requests and dispatch delivery fleet.</p>
				</div>

				<%- include('../partials/alerts') %>

					<% if (fuelRequests.length===0) { %>
						<div class="text-center py-5"
							style="background: rgba(255,255,255,0.02); border-radius: 30px; border: 2px dashed #333;">
							<i class="fas fa-gas-pump mb-4" style="font-size: 4rem; color: #444;"></i>
							<h3 class="text-muted">No Pending Requests</h3>
							<p class="text-muted">All fuel delivery orders have been successfully assigned.</p>
						</div>
						<% } else { %>
							<div class="fuel-request-grid">
								<% fuelRequests.forEach((request, index)=> { %>
									<div class="fuel-job-card">
										<!-- Side Summary -->
										<div class="fuel-job-side">
											<span class="job-index-tag">Request #<%= request._id.toString().slice(-6) %>
													</span>

											<div class="fuel-type-badge">
												<i class="fas fa-filter me-2 text-warning"></i>
												<%= request.subServices && request.subServices.length> 0 ?
													request.subServices.join(' + ') : 'Standard Fuel' %>
											</div>

											<div class="delivery-destination">
												<h6>Terminal Point</h6>
												<p><i class="fas fa-location-dot me-2 text-warning"></i>
													<%= request.address %>
												</p>
											</div>

											<div class="mt-4 small opacity-75">
												<i class="fas fa-clock me-2"></i> Received <%= new
													Date(request.createdAt).toLocaleTimeString([], { hour: '2-digit' ,
													minute: '2-digit' }) %>
											</div>
										</div>

										<!-- Main Content -->
										<div class="fuel-job-main">
											<div class="customer-card-mini">
												<div class="cust-avatar-box">
													<%= request.customer.firstName.charAt(0) %>
												</div>
												<div class="cust-meta-v">
													<h5>
														<%= request.customer.firstName %>
															<%= request.customer.lastName %>
													</h5>
													<span>Personalized Assistance Request</span>
												</div>
											</div>

											<div class="order-details-summary">
												<div class="order-detail-item">
													<label>Fuel Quantity</label>
													<span class="text-warning">
														<%= request.quantity || 'N/A' %> Litres
													</span>
												</div>
												<div class="order-detail-item">
													<label>Contact Auth</label>
													<span>+91 <%= request.customer.phone %></span>
												</div>
												<div class="order-detail-item">
													<label>Est. Revenue</label>
													<span>₹<%= request.totalAmount || request.baseAmount || 500 %>
															</span>
												</div>
											</div>

											<div class="dispatch-control-pane">
												<div class="pane-header">
													<i class="fas fa-shuttle-van"></i>
													Authorize Fleet Dispatch
												</div>
												<form action="/admin/assign-fuel-boy/<%= request._id %>" method="POST"
													class="dispatch-input-group">
													<select name="fuelBoyId" class="select-fleet" required>
														<option disabled selected value="">Select Available Fleet
															Operator</option>
														<% request.fuelBoys.forEach(function(boy) { %>
															<option value="<%= boy._id %>">
																<%= boy.firstName %>
																	<%= boy.lastName %> (Verified)
															</option>
															<% }); %>
													</select>
													<button type="submit" class="btn-authorize-fleet">
														Assign & Dispatch
													</button>
												</form>
											</div>
										</div>
									</div>
									<% }); %>
							</div>
							<% } %>
			</div>

			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>