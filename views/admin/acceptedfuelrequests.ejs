<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Fuel Delivery Logs | RoadAid Admin</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.page-header {
			margin-bottom: 3rem;
			border-left: 5px solid var(--accent-yellow);
			padding-left: 1.5rem;
			display: flex;
			justify-content: space-between;
			align-items: center;
		}

		.page-header h2 {
			font-weight: 800;
			margin: 0;
			text-transform: uppercase;
			letter-spacing: 1px;
		}

		.fulfilled-sticker {
			background: #111;
			padding: 0.5rem 1.5rem;
			border-radius: 50px;
			border: 1px solid #333;
			display: flex;
			align-items: center;
			gap: 1rem;
		}

		.fulfilled-sticker span:first-child {
			color: #2ecc71;
			font-weight: 800;
			font-size: 1.25rem;
		}

		.fulfilled-sticker span:last-child {
			color: #888;
			font-size: 0.8rem;
			text-transform: uppercase;
			font-weight: 700;
		}

		.log-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
			gap: 2rem;
		}

		.fulfilled-job-card {
			background: var(--card-bg);
			border-radius: 30px;
			overflow: hidden;
			color: var(--text-dark);
			border: 1px solid #333;
			transition: var(--transition);
			display: flex;
			flex-direction: column;
		}

		.fulfilled-job-card:hover {
			transform: translateY(-5px);
			box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
		}

		.card-log-header {
			background: #111;
			padding: 1.5rem 2rem;
			display: flex;
			justify-content: space-between;
			align-items: center;
		}

		.log-id-tag {
			color: var(--accent-yellow);
			font-weight: 800;
			font-size: 0.75rem;
			letter-spacing: 1px;
		}

		.status-pill-success {
			background: #2ecc71;
			color: #fff;
			padding: 0.3rem 0.8rem;
			border-radius: 50px;
			font-size: 0.65rem;
			font-weight: 800;
			text-transform: uppercase;
		}

		.card-log-body {
			padding: 2rem;
			flex-grow: 1;
		}

		.delivery-participants {
			display: flex;
			align-items: center;
			justify-content: space-between;
			margin-bottom: 2rem;
			padding-bottom: 1.5rem;
			border-bottom: 1px solid #eee;
		}

		.participant-v {
			text-align: center;
		}

		.participant-v .avatar-v {
			width: 50px;
			height: 50px;
			background: #f0f0f0;
			border-radius: 15px;
			display: flex;
			align-items: center;
			justify-content: center;
			margin: 0 auto 0.5rem;
			font-weight: 800;
			color: #111;
		}

		.participant-v label {
			display: block;
			font-size: 0.6rem;
			text-transform: uppercase;
			font-weight: 700;
			color: #999;
		}

		.participant-v span {
			font-size: 0.85rem;
			font-weight: 700;
			color: #333;
		}

		.flow-connector {
			flex: 1;
			height: 2px;
			background: dashed #ddd;
			margin: 0 1rem;
			position: relative;
			top: -10px;
		}

		.log-details-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 1.5rem;
		}

		.log-field label {
			display: block;
			font-size: 0.65rem;
			text-transform: uppercase;
			color: #999;
			font-weight: 700;
			margin-bottom: 0.25rem;
		}

		.log-field span {
			font-weight: 700;
			color: #333;
			font-size: 0.9rem;
			line-height: 1.4;
		}

		.vehicle-visual-box {
			margin-top: 1.5rem;
			border-radius: 15px;
			overflow: hidden;
			border: 2px solid #eee;
			aspect-ratio: 16/9;
		}

		.vehicle-visual-box img {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}

		@media (max-width: 991px) {
			#main-wrapper {
				margin-left: 0;
				padding: 1.5rem;
			}
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
		<%- include('../partials/adminSidebar', { title: 'Completed Fuel Logs' }) %>

			<div id="main-wrapper">
				<div class="page-header">
					<div>
						<h2>Fulfillment <span>Logs</span></h2>
						<p class="text-muted mb-0">Audited records of completed fuel delivery operations.</p>
					</div>
					<div class="fulfilled-sticker">
						<span>
							<%= acceptedfuel.length %>
						</span>
						<span>Successful Orders</span>
					</div>
				</div>

				<%- include('../partials/alerts') %>

					<% if (acceptedfuel.length===0) { %>
						<div class="text-center py-5"
							style="background: rgba(255,255,255,0.02); border-radius: 30px; border: 2px dashed #333;">
							<i class="fas fa-clipboard-check mb-4" style="font-size: 4rem; color: #444;"></i>
							<h3 class="text-muted">No Logs Available</h3>
							<p class="text-muted">Completed fuel records will be archived here upon successful delivery.
							</p>
						</div>
						<% } else { %>
							<div class="log-grid">
								<% acceptedfuel.forEach((service, index)=> { %>
									<div class="fulfilled-job-card">
										<div class="card-log-header">
											<span class="log-id-tag">FLOG #<%= service._id.toString().slice(-6) %>
													</span>
											<span class="status-pill-success">Fulfilled</span>
										</div>

										<div class="card-log-body">
											<div class="delivery-participants">
												<div class="participant-v">
													<div class="avatar-v" style="background: #e3f2fd; color: #1976d2;">
														<%= service.customer.firstName.charAt(0) %>
													</div>
													<label>Client</label>
													<span>
														<%= service.customer.firstName %>
													</span>
												</div>
												<div class="flow-connector"></div>
												<div class="participant-v">
													<div class="avatar-v" style="background: #e8f5e9; color: #2e7d32;">
														<%= service.fueldeliveryboy.firstName.charAt(0) %>
													</div>
													<label>Fleet Op</label>
													<span>
														<%= service.fueldeliveryboy.firstName %>
													</span>
												</div>
											</div>

											<div class="log-details-grid">
												<div class="log-field">
													<label>Commodity</label>
													<span>
														<%= service.subServices && service.subServices.length> 0 ?
															service.subServices.join(' / ') : 'Standard Fuel' %>
													</span>
												</div>
												<div class="log-field">
													<label>Volume Delivered</label>
													<span class="text-success">
														<%= service.quantity || 'N/A' %> Litres
													</span>
												</div>
												<div class="log-field" style="grid-column: span 2;">
													<label>Delivery Endpoint</label>
													<span><i class="fas fa-location-dot me-2 text-danger"></i>
														<%= service.address %>
													</span>
												</div>
											</div>

											<% if (service.vehiclePhotoPath) { %>
												<div class="vehicle-visual-box">
													<img src="/<%= service.vehiclePhotoPath %>"
														alt="Verified Vehicle Delivery">
												</div>
												<% } %>
										</div>
									</div>
									<% }); %>
							</div>
							<% } %>
			</div>

			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>