<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Live Tracking | FuelAid</title>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

  <!-- CSS -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
  <link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
  <link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

  <style>
    body {
      background-color: var(--primary-bg);
      color: var(--text-light);
      font-family: var(--font-main);
    }

    #main-wrapper {
      margin-left: 280px;
      padding: 2.5rem;
      min-height: 100vh;
    }

    .page-header {
      margin-bottom: 3rem;
      border-left: 5px solid var(--accent-yellow);
      padding-left: 1.5rem;
    }

    .page-header h2 {
      font-weight: 800;
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .tracking-card {
      background: var(--card-bg);
      border-radius: 25px;
      overflow: hidden;
      color: var(--text-dark);
      margin-bottom: 3rem;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
      border: 1px solid #333;
    }

    .tracking-header {
      background: #111;
      padding: 1.5rem 2.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid #333;
    }

    .tracking-header h4 {
      color: var(--accent-yellow);
      margin: 0;
      font-weight: 800;
      text-transform: uppercase;
      font-size: 1rem;
      letter-spacing: 1px;
    }

    .live-indicator {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: #ff4444;
      font-weight: 700;
      font-size: 0.8rem;
      text-transform: uppercase;
    }

    .pulse-dot {
      width: 10px;
      height: 10px;
      background: #ff4444;
      border-radius: 50%;
      animation: pulse 1.5s infinite;
    }

    @keyframes pulse {
      0% {
        opacity: 1;
        transform: scale(1);
      }

      50% {
        opacity: 0.5;
        transform: scale(1.2);
      }

      100% {
        opacity: 1;
        transform: scale(1);
      }
    }

    .tracking-body {
      padding: 2.5rem;
    }

    .provider-profile {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      background: #f8f9fa;
      padding: 1.5rem;
      border-radius: 20px;
      margin-bottom: 2rem;
      border: 1px solid #eee;
    }

    .provider-avatar {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid var(--accent-yellow);
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }

    .provider-info h5 {
      margin: 0;
      font-weight: 800;
      color: #111;
    }

    .provider-info p {
      margin: 0;
      font-weight: 600;
      color: #777;
      font-size: 0.9rem;
    }

    .info-row-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .info-box {
      background: #fff;
      padding: 1.2rem;
      border-radius: 15px;
      border: 1px solid #eee;
    }

    .info-box label {
      display: block;
      font-size: 0.7rem;
      text-transform: uppercase;
      font-weight: 700;
      color: #999;
      margin-bottom: 0.5rem;
    }

    .info-box span {
      font-weight: 800;
      color: #111;
      font-size: 1rem;
    }

    .stat-value {
      color: var(--accent-yellow) !important;
    }

    .map-container {
      height: 450px;
      border-radius: 20px;
      overflow: hidden;
      border: 4px solid #fff;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      position: relative;
    }

    .map-overlay-stats {
      position: absolute;
      bottom: 20px;
      left: 20px;
      z-index: 1000;
      background: rgba(0, 0, 0, 0.8);
      backdrop-filter: blur(10px);
      padding: 1rem 2rem;
      border-radius: 50px;
      display: flex;
      gap: 2rem;
      border: 1px solid #444;
    }

    .overlay-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      color: #fff;
      font-weight: 700;
      font-size: 0.9rem;
    }

    .overlay-item i {
      color: var(--accent-yellow);
    }

    /* Success/Completion Styling */
    .completed-banner {
      background: #fffdf5;
      border: 2px solid var(--accent-yellow);
      border-radius: 20px;
      padding: 3rem;
      text-align: center;
    }

    .completed-banner i {
      font-size: 4rem;
      color: var(--accent-yellow);
      margin-bottom: 1.5rem;
    }

    /* Modal Styling */
    .modal-content {
      border-radius: 25px;
      border: none;
      overflow: hidden;
      background: var(--primary-bg);
      color: var(--text-light);
    }

    .modal-header {
      background: var(--accent-yellow);
      color: #000;
      border: none;
      padding: 1.5rem 2rem;
    }

    .modal-header h5 {
      font-weight: 800;
      text-transform: uppercase;
    }

    .modal-body {
      padding: 2rem;
    }

    .feedback-select {
      background: #1a1a1a;
      border: 2px solid #333;
      color: #fff;
      padding: 1rem;
      border-radius: 12px;
      width: 100%;
      margin-bottom: 1.5rem;
    }

    .feedback-textarea {
      background: #1a1a1a;
      border: 2px solid #333;
      color: #fff;
      padding: 1rem;
      border-radius: 12px;
      width: 100%;
    }

    @media (max-width: 991px) {
      #main-wrapper {
        margin-left: 0;
        padding: 1.5rem;
      }
    }
  </style>
</head>

<body class="dashboard-body">
  <%- include('../partials/header') %>
    <%- include('../partials/customerSidebar', { title: 'Live Tracking' }) %>

      <div id="main-wrapper">
        <div class="page-header">
          <h2>Live <span>Tracking</span></h2>
          <p class="text-muted mb-0">Monitor your active service requests in real-time.</p>
        </div>

        <%- include('../partials/alerts') %>

          <% if (requests.length===0) { %>
            <div class="empty-state text-center py-5"
              style="background: rgba(255,255,255,0.02); border-radius: 20px; border: 2px dashed #333;">
              <i class="fas fa-satellite-dish mb-4" style="font-size: 4rem; color: #444;"></i>
              <h3 class="text-muted">No Active Requests</h3>
              <p class="text-muted">You don't have any requests being tracked right now.</p>
              <a href="/customer/request-service" class="btn-yellow mt-3">Request Assistance</a>
            </div>
            <% } else { %>
              <div class="tracking-list">
                <% requests.forEach((request, index)=> { %>
                  <div class="tracking-card">
                    <div class="tracking-header">
                      <h4>
                        <%= request.serviceCategory %> Assistance - #<%= (request._id).toString().slice(-6) %>
                      </h4>
                      <% if (request.status !=='completed' ) { %>
                        <div class="live-indicator">
                          <div class="pulse-dot"></div>
                          Live Tracking
                        </div>
                        <% } %>
                    </div>

                    <div class="tracking-body">
                      <% if (request.status !=='completed' ) { %>
                        <!-- Provider Profile -->
                        <% if (request.mechanic || request.fueldeliveryboy) { %>
                          <% const provider=request.mechanic || request.fueldeliveryboy; %>
                            <div class="provider-profile">
                              <img src="<%= provider.profilePic || '/assets/images/default-avatar.png' %>"
                                class="provider-avatar" alt="Provider">
                              <div class="provider-info">
                                <h5>
                                  <%= provider.firstName %>
                                    <%= provider.lastName %>
                                </h5>
                                <p><i class="fas fa-phone-alt me-2 text-warning"></i> +91 <%= provider.phone %>
                                </p>
                                <p><i class="fas fa-id-card me-2 text-warning"></i> Vehicle: <%= provider.licensePlate
                                    %>
                                </p>
                              </div>
                            </div>
                            <% } else { %>
                              <div class="alert alert-dark p-4 border-0 mb-4"
                                style="background: #f8f9fa; color: #555; border-radius: 15px;">
                                <i class="fas fa-spinner fa-spin me-3"></i> <strong>Searching for nearby
                                  providers...</strong>
                              </div>
                              <% } %>

                                <!-- Info Row -->
                                <div class="info-row-grid">
                                  <div class="info-box">
                                    <label>Current Status</label>
                                    <span id="status-<%= index %>">
                                      <%= request.status==='accepted' ? 'Provider Assigned' : 'Awaiting Connection' %>
                                    </span>
                                  </div>
                                  <div class="info-box">
                                    <label>Estimated Arrival</label>
                                    <span id="eta-<%= index %>" class="stat-value">Calculating...</span>
                                  </div>
                                  <div class="info-box">
                                    <label>Service Price</label>
                                    <span>₹<%= request.totalAmount || request.baseAmount %></span>
                                  </div>
                                </div>

                                <!-- Map Container -->
                                <div class="map-container">
                                  <div id="map-<%= index %>" style="height: 100%;"></div>
                                  <div class="map-overlay-stats">
                                    <div class="overlay-item">
                                      <i class="fas fa-map-marked-alt"></i>
                                      <span id="distance-<%= index %>">0.0 km</span>
                                    </div>
                                    <div class="overlay-item">
                                      <i class="fas fa-tachometer-alt"></i>
                                      <span>40 km/h (Avg)</span>
                                    </div>
                                  </div>
                                </div>

                                <% } else { %>
                                  <!-- Completed View -->
                                  <div class="completed-banner">
                                    <i class="fas fa-check-circle"></i>
                                    <h3>Service Successfully Completed</h3>
                                    <p class="text-muted mb-4">Your <%= request.serviceCategory %> assistance request
                                        has been fulfilled. We hope you're back on the road safely!</p>

                                    <div class="d-flex justify-content-center gap-3">
                                      <% if (!request.isPaid) { %>
                                        <a href="/customer/payment/<%= request._id %>" class="btn-yellow px-5 py-3">Pay
                                          Bill: ₹<%= request.totalAmount || request.baseAmount %></a>
                                        <% } %>

                                          <% if (!request.feedback) { %>
                                            <button class="btn btn-outline-dark rounded-pill px-5"
                                              onclick="openFeedbackModal('<%= request._id %>')">
                                              Rate Our Quality
                                            </button>
                                            <% } %>
                                    </div>
                                  </div>
                                  <% } %>
                    </div>
                  </div>
                  <% }) %>
              </div>
              <% } %>
      </div>

      <!-- Feedback Modal -->
      <div class="modal fade" id="feedbackModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <form id="feedbackForm" class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title"><i class="fas fa-star me-2"></i>Rate Service</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <label class="form-label text-light">How was your experience?</label>
              <select class="feedback-select" name="rating" required>
                <option value="" selected disabled>Select Rating</option>
                <option value="5">⭐⭐⭐⭐⭐ 5 - Excellent</option>
                <option value="4">⭐⭐⭐⭐ 4 - Very Good</option>
                <option value="3">⭐⭐⭐ 3 - Average</option>
                <option value="2">⭐⭐ 2 - Poor</option>
                <option value="1">⭐ 1 - Terrible</option>
              </select>

              <label class="form-label text-light">Any specific comments?</label>
              <textarea class="feedback-textarea" name="feedback" rows="4"
                placeholder="What did we do well? What could we improve?"></textarea>

              <input type="hidden" name="requestId" id="requestId">

              <button type="submit" class="btn-yellow w-100 mt-4 py-3">Submit Review</button>
            </div>
          </form>
        </div>
      </div>

      <!-- Tracking Assets -->
      <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
      <script src="/socket.io/socket.io.js"></script>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

      <div id="tracking-data" data-requests='<%- JSON.stringify(requests) %>'></div>

      <script>
        const socket = io();
        const requestData = document.getElementById('tracking-data').dataset.requests;
        const requests = JSON.parse(requestData);

        const markers = {
          mechanic: {},
          fuel: {}
        };

        requests.forEach((req, idx) => {
          if (!req.status || req.status === 'completed') return;

          const map = L.map(`map-${idx}`, { zoomControl: false }).setView([req.latitude, req.longitude], 15);

          // Premium Dark Map Style (OpenStreetMap Alt)
          L.tileLayer('https://{s}.tile.openstreetmap.fr/hot/{z}/{x}/{y}.png', {
            attribution: '&copy; RoadAid Tracking'
          }).addTo(map);

          // Customer Marker
          L.marker([req.latitude, req.longitude], {
            icon: L.icon({
              iconUrl: 'https://cdn-icons-png.flaticon.com/512/1946/1946433.png',
              iconSize: [35, 35],
            })
          }).addTo(map).bindPopup("<b>You are here</b>").openPopup();

          // Provider Tracking Logic
          const provider = req.mechanic || req.fueldeliveryboy;
          const type = req.mechanic ? 'mechanic' : 'fuel';

          if (provider) {
            const providerMarker = L.marker([provider.latitude, provider.longitude], {
              icon: L.icon({
                iconUrl: 'https://cdn-icons-png.flaticon.com/512/854/854878.png',
                iconSize: [35, 35],
              })
            }).addTo(map);

            providerMarker.bindPopup(`<b>${provider.firstName} (On the way)</b>`);

            if (!markers[type][provider._id]) markers[type][provider._id] = [];
            markers[type][provider._id].push({ map, marker: providerMarker, request: req, requestIndex: idx });
          }
        });

        // Shared Logic for Location Updates
        function handleLocationUpdate(data, type) {
          const list = markers[type][data.mechanicId || data.fuelId];
          if (!list) return;

          list.forEach(({ map, marker, request, requestIndex }) => {
            const { lat, lng, status } = data;

            if (status === 'completed') {
              location.reload();
              return;
            }

            marker.setLatLng([lat, lng]);
            map.panTo([lat, lng]);

            // Calculate Distance & ETA
            const dist = haversineDistance(lat, lng, request.latitude, request.longitude);
            document.getElementById(`distance-${requestIndex}`).textContent = `${dist.toFixed(1)} km`;

            const etaMin = Math.round((dist / 40) * 60);
            document.getElementById(`eta-${requestIndex}`).textContent = etaMin < 2 ? 'Arriving Now' : `${etaMin} mins`;

            const statusEl = document.getElementById(`status-${requestIndex}`);
            if (dist < 0.2) statusEl.textContent = 'At Your Location';
            else statusEl.textContent = 'On the Way';
          });
        }

        socket.on('updateMechanicLocation', data => handleLocationUpdate(data, 'mechanic'));
        socket.on('updateFuelLocation', data => handleLocationUpdate(data, 'fuel'));

        function haversineDistance(lat1, lon1, lat2, lon2) {
          const R = 6371;
          const dLat = (lat2 - lat1) * Math.PI / 180;
          const dLon = (lon2 - lon1) * Math.PI / 180;
          const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
            Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
            Math.sin(dLon / 2) * Math.sin(dLon / 2);
          return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        }

        function openFeedbackModal(requestId) {
          document.getElementById('requestId').value = requestId;
          new bootstrap.Modal(document.getElementById('feedbackModal')).show();
        }

        document.getElementById('feedbackForm').addEventListener('submit', async (e) => {
          e.preventDefault();
          const formData = new FormData(e.target);
          const res = await fetch(`/feedback/${formData.get('requestId')}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              rating: formData.get('rating'),
              feedback: formData.get('feedback')
            })
          });
          if (res.ok) location.reload();
        });
      </script>
</body>

</html>