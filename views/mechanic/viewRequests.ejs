<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Roadside Service Quests | RoadAid</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.quest-card {
			background: var(--card-bg);
			border-radius: 25px;
			padding: 2.5rem;
			margin-bottom: 2rem;
			border: 1px solid #eee;
			color: var(--text-dark);
			transition: var(--transition);
			position: relative;
			overflow: hidden;
		}

		.quest-card:hover {
			transform: translateY(-5px);
			box-shadow: 0 15px 40px rgba(0,0,0,0.1);
		}

		.quest-type-tag {
			background: #111;
			color: var(--accent-yellow);
			padding: 0.5rem 1.25rem;
			border-radius: 50px;
			font-size: 0.7rem;
			font-weight: 800;
			text-transform: uppercase;
			letter-spacing: 1.5px;
			display: inline-block;
			margin-bottom: 1.5rem;
		}

		.assigned-tag {
			background: #27ae60;
			color: white;
		}

		.info-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
			gap: 2rem;
		}

		.info-block {
			display: flex;
			gap: 1rem;
		}

		.info-block i {
			font-size: 1.2rem;
			color: var(--accent-yellow);
			background: #111;
			width: 40px;
			height: 40px;
			border-radius: 12px;
			display: flex;
			align-items: center;
			justify-content: center;
			flex-shrink: 0;
		}

		.info-label {
			font-size: 0.75rem;
			font-weight: 700;
			color: #888;
			text-transform: uppercase;
			letter-spacing: 1px;
			margin-bottom: 0.25rem;
		}

		.info-value {
			font-weight: 700;
			font-size: 0.95rem;
			word-break: break-all;
		}

		.vehicle-preview {
			width: 100%;
			max-width: 300px;
			border-radius: 20px;
			margin-top: 1.5rem;
			border: 1px solid #eee;
			box-shadow: 0 10px 30px rgba(0,0,0,0.1);
		}

		.empty-quest-state {
			text-align: center;
			padding: 5rem;
			background: rgba(255,255,255,0.03);
			border-radius: 30px;
			border: 1px dashed #333;
			color: #666;
		}

		.empty-quest-state i {
			font-size: 4rem;
			color: #333;
			margin-bottom: 2rem;
		}

		@media (max-width: 991px) {
			#main-wrapper { margin-left: 0; padding: 1.5rem; }
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
	<%- include('../partials/mechanicSidebar') %>

	<div id="main-wrapper">
		<%- include('../partials/alerts') %>

		<div class="d-flex justify-content-between align-items-end mb-5">
			<div>
				<h1 class="hero-title mb-0">Active <span>Quests</span></h1>
				<p class="text-muted">Broadcast of pending and assigned service missions within your sector.</p>
			</div>
			<div class="text-end d-none d-md-block">
				<div class="badge bg-dark p-3 rounded-pill">
					<i class="fas fa-satellite-dish pulse me-2 text-warning"></i>
					Scanning Sector 4
				</div>
			</div>
		</div>

		<% 
		const filteredServices = requestedServices.filter(service => 
			service.serviceCategory?.toLowerCase() !== 'fuel'
		); 
		%>

		<!-- Assigned Section -->
		<% if (assignedServices && assignedServices.length > 0) { %>
			<h3 class="section-title mb-4"><i class="fas fa-user-tag me-2"></i> Directly <span>Assigned</span></h3>
			<% assignedServices.forEach((service, index) => { %>
				<div class="quest-card" style="border-left: 8px solid #27ae60;">
					<div class="quest-type-tag assigned-tag">Direct Command</div>
					<div class="info-grid">
						<div class="info-block">
							<i class="fas fa-tools"></i>
							<div>
								<div class="info-label">Operation</div>
								<div class="info-value"><%= service.serviceCategory || 'Standard Repair' %></div>
							</div>
						</div>
						<div class="info-block">
							<i class="fas fa-list-ul"></i>
							<div>
								<div class="info-label">Specialties</div>
								<div class="info-value">
									<% if (service.subServices && service.subServices.length > 0) { %>
										<%= service.subServices.join(", ") %>
									<% } else { %>Basic Fix<% } %>
								</div>
							</div>
						</div>
						<div class="info-block">
							<i class="fas fa-user-circle"></i>
							<div>
								<div class="info-label">Client</div>
								<div class="info-value"><%= service.customer.firstName %> <%= service.customer.lastName %></div>
							</div>
						</div>
						<div class="info-block">
							<i class="fas fa-map-marker-alt"></i>
							<div>
								<div class="info-label">Coordinates</div>
								<div class="info-value"><%= service.address %></div>
							</div>
						</div>
					</div>

					<% if (service.vehiclePhotoPath) { %>
						<img src="/<%= service.vehiclePhotoPath %>" class="vehicle-preview" alt="Intel Photo">
					<% } %>

					<div class="mt-4 pt-4 border-top d-flex gap-3">
						<form action="/mechanic/service/accept/<%= service._id %>" method="POST" class="flex-grow-1">
							<button type="submit" class="btn-yellow w-100">Establish Connection (Accept)</button>
						</form>
						<form action="/mechanic/service/reject/<%= service._id %>" method="POST">
							<button type="submit" class="btn btn-outline-danger px-4" style="border-radius: 15px; height: 55px;">Abort</button>
						</form>
					</div>
				</div>
			<% }); %>
		<% } %>

		<!-- Available Section -->
		<h3 class="section-title mb-4 mt-5"><i class="fas fa-broadcast-tower me-2"></i> Open <span>Signals</span></h3>
		<% if (filteredServices.length > 0) { %>
			<% filteredServices.forEach((service, index) => { %>
				<div class="quest-card">
					<div class="quest-type-tag"><%= service.serviceCategory || 'Public Request' %></div>
					<div class="info-grid">
						<div class="info-block">
							<i class="fas fa-tachometer-alt"></i>
							<div>
								<div class="info-label">Distance</div>
								<div class="info-value"><%= service.distance ? (service.distance / 1000).toFixed(2) + ' km' : 'Calculating...' %></div>
							</div>
						</div>
						<div class="info-block">
							<i class="fas fa-clock"></i>
							<div>
								<div class="info-label">Transmission Time</div>
								<div class="info-value"><%= new Date(service.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></div>
							</div>
						</div>
						<div class="info-block">
							<i class="fas fa-map-pin"></i>
							<div>
								<div class="info-label">Sector</div>
								<div class="info-value"><%= service.address.substring(0, 40) %>...</div>
							</div>
						</div>
					</div>

					<div class="mt-4 pt-4 border-top">
						<form action="/mechanic/service/accept/<%= service._id %>" method="POST">
							<button type="submit" class="btn-yellow px-5">Intercept Quest</button>
						</form>
					</div>
				</div>
			<% }); %>
		<% } else if (!assignedServices || assignedServices.length === 0) { %>
			<div class="empty-quest-state">
				<i class="fas fa-radar"></i>
				<h4>No active signals detected in your sector.</h4>
				<p>Stand by for incoming transmissions from nearby clients.</p>
			</div>
		<% } %>
	</div>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
	<script>
		if (navigator.geolocation) {
			navigator.geolocation.getCurrentPosition((pos) => {
				fetch('/mechanic/updateLocation', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ latitude: pos.coords.latitude, longitude: pos.coords.longitude }),
				});
			});
		}
	</script>
</body>
</html>
