<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Mission Control | RoadAid</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.mission-card {
			background: var(--card-bg);
			border-radius: 25px;
			padding: 2.5rem;
			margin-bottom: 2rem;
			border: 1px solid #eee;
			color: var(--text-dark);
			transition: var(--transition);
			position: relative;
			overflow: hidden;
		}

		.mission-status-badge {
			position: absolute;
			top: 0;
			right: 0;
			padding: 0.75rem 2rem;
			font-size: 0.7rem;
			font-weight: 800;
			text-transform: uppercase;
			letter-spacing: 1.5px;
			border-radius: 0 0 0 20px;
		}

		.status-accepted { background: var(--accent-yellow); color: #000; }
		.status-progress { background: #3498db; color: #fff; }

		.intel-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
			gap: 2rem;
			margin-top: 2rem;
		}

		.intel-box {
			display: flex;
			gap: 1rem;
		}

		.intel-box i {
			font-size: 1.1rem;
			color: var(--accent-yellow);
			background: #111;
			width: 35px;
			height: 35px;
			border-radius: 10px;
			display: flex;
			align-items: center;
			justify-content: center;
			flex-shrink: 0;
		}

		.intel-label {
			font-size: 0.7rem;
			font-weight: 700;
			color: #888;
			text-transform: uppercase;
			letter-spacing: 1px;
			margin-bottom: 0.2rem;
		}

		.intel-value {
			font-weight: 700;
			font-size: 0.9rem;
		}

		.intel-photo {
			width: 100%;
			max-width: 400px;
			border-radius: 20px;
			margin-top: 2rem;
			border: 1px solid #eee;
		}

		.empty-mission-state {
			text-align: center;
			padding: 6rem;
			background: rgba(255,255,255,0.03);
			border-radius: 30px;
			border: 1px dashed #333;
			color: #666;
		}

		@media (max-width: 991px) {
			#main-wrapper { margin-left: 0; padding: 1.5rem; }
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
	<%- include('../partials/mechanicSidebar') %>

	<div id="main-wrapper">
		<%- include('../partials/alerts') %>

		<div class="mb-5">
			<h1 class="hero-title mb-0">Active <span>Missions</span></h1>
			<p class="text-muted">High-priority service tasks currently under your technical command.</p>
		</div>

		<% if (acceptedServices.length === 0) { %>
			<div class="empty-mission-state">
				<i class="fas fa-satellite-dish mb-4" style="font-size: 4rem; color: #333;"></i>
				<h4>No active missions assigned.</h4>
				<p>Intercept new signals from the available quests sector to begin operations.</p>
				<a href="/mechanic/viewRequests" class="btn-yellow mt-4">Search available quests</a>
			</div>
		<% } else { %>
			<% acceptedServices.forEach((service, index) => { %>
				<div class="mission-card">
					<div class="mission-status-badge <%= service.status === 'in-progress' ? 'status-progress' : 'status-accepted' %>">
						<%= service.status === 'in-progress' ? 'LIVE: In Progress' : 'Confirmed: Stand By' %>
					</div>

					<h4 class="fw-800 mb-1"><%= service.serviceCategory || 'Rapid Repair Strike' %></h4>
					<p class="small text-muted mb-4">Mission ID: #<%= service._id.toString().substring(18).toUpperCase() %></p>

					<div class="intel-grid">
						<div class="intel-box">
							<i class="fas fa-user"></i>
							<div>
								<div class="intel-label">Client</div>
								<div class="intel-value"><%= service.customer.firstName %> <%= service.customer.lastName %></div>
							</div>
						</div>
						<div class="intel-box">
							<i class="fas fa-phone"></i>
							<div>
								<div class="intel-label">Comms Line</div>
								<div class="intel-value"><%= service.customer.phone %></div>
							</div>
						</div>
						<div class="intel-box">
							<i class="fas fa-map-marker-alt"></i>
							<div>
								<div class="intel-label">Coordinates</div>
								<div class="intel-value"><%= service.address %></div>
							</div>
						</div>
						<div class="intel-box">
							<i class="fas fa-tools"></i>
							<div>
								<div class="intel-label">Specs</div>
								<div class="intel-value">
									<% if (service.subServices && service.subServices.length > 0) { %>
										<%= service.subServices.join(", ") %>
									<% } else { %>Standard Extraction<% } %>
								</div>
							</div>
						</div>
					</div>

					<% if (service.vehiclePhotoPath) { %>
						<img src="/<%= service.vehiclePhotoPath %>" class="intel-photo" alt="Quest Intel">
					<% } %>

					<div class="mt-5 pt-4 border-top d-flex gap-3">
						<% if (service.status === 'accepted') { %>
							<form action="/mechanic/service/inprogress/<%= service._id %>" method="POST" class="flex-grow-1">
								<button type="submit" class="btn-yellow w-100">Synchronize & Start Service</button>
							</form>
						<% } %>
						<form action="/mechanic/service/complete/<%= service._id %>" method="POST" class="flex-grow-1">
							<button type="submit" class="btn-black-premium w-100">Finalize & Mark Completed</button>
						</form>
					</div>
				</div>
			<% }); %>
		<% } %>
	</div>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
	<script src="/assets/js/script.js"></script>
</body>
</html>
