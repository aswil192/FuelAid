<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>
		<%= typeof title !='undefined' ? title : "Customer Dashboard | FuelAid" %>
	</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2rem;
			min-height: 100vh;
			transition: all 0.3s ease;
		}

		.customer-hero {
			background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url('/assets/images/i1.jpg');
			background-size: cover;
			background-position: center;
			border-radius: 20px;
			padding: 4rem 2rem;
			margin-bottom: 2.5rem;
			border: 1px solid #333;
			box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
		}

		.hero-title {
			font-weight: 800;
			font-size: 3.5rem;
			margin-bottom: 1rem;
			letter-spacing: -1px;
		}

		.hero-title span {
			color: var(--accent-yellow);
		}

		.hero-subtitle {
			font-size: 1.2rem;
			color: #ccc;
			max-width: 600px;
			line-height: 1.6;
		}

		.section-title {
			display: flex;
			align-items: center;
			gap: 1rem;
			margin-bottom: 2rem;
			font-weight: 700;
			font-size: 1.5rem;
			text-transform: uppercase;
			letter-spacing: 1px;
		}

		.section-title i {
			color: var(--accent-yellow);
		}

		/* Quick Action Cards */
		.quick-actions {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
			gap: 1.5rem;
			margin-bottom: 4rem;
		}

		.action-card {
			background: var(--card-bg);
			border-radius: var(--border-radius);
			padding: 2.5rem 2rem;
			text-align: center;
			transition: var(--transition);
			text-decoration: none;
			color: var(--text-dark);
			border: 1px solid rgba(255, 255, 255, 0.1);
			position: relative;
			overflow: hidden;
		}

		.action-card::before {
			content: '';
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 5px;
			background: var(--accent-yellow);
			transform: scaleX(0);
			transition: var(--transition);
		}

		.action-card:hover {
			transform: translateY(-10px);
			box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
		}

		.action-card:hover::before {
			transform: scaleX(1);
		}

		.action-icon {
			font-size: 3rem;
			color: var(--accent-yellow);
			margin-bottom: 1.5rem;
			display: block;
		}

		.action-card h3 {
			font-weight: 700;
			margin-bottom: 0.75rem;
			font-size: 1.4rem;
		}

		.action-card p {
			color: #666;
			font-size: 0.95rem;
			margin-bottom: 0;
		}

		/* Pricing Section */
		.category-tabs {
			background: rgba(255, 255, 255, 0.05);
			padding: 0.5rem;
			border-radius: 50px;
			display: inline-flex;
			gap: 0.5rem;
			margin-bottom: 2rem;
			border: 1px solid #333;
		}

		.category-tab {
			padding: 0.75rem 1.5rem;
			border: none;
			background: transparent;
			color: #fff;
			border-radius: 50px;
			font-weight: 600;
			transition: var(--transition);
		}

		.category-tab.active {
			background: var(--accent-yellow);
			color: #000;
		}

		.price-card {
			background: var(--card-bg);
			border-radius: var(--border-radius);
			overflow: hidden;
			color: var(--text-dark);
			height: 100%;
			transition: var(--transition);
		}

		.price-header {
			padding: 2rem;
			text-align: center;
			background: #fcfcfc;
			border-bottom: 1px solid #eee;
		}

		.price-amount {
			font-size: 2.5rem;
			font-weight: 800;
			color: var(--text-dark);
			margin: 1rem 0;
		}

		.price-name {
			font-weight: 700;
			font-size: 1.1rem;
			text-transform: uppercase;
			letter-spacing: 1px;
			color: #888;
		}

		.price-body {
			padding: 2rem;
		}

		.price-feature {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			margin-bottom: 1rem;
			color: #555;
			font-size: 0.9rem;
		}

		.price-feature i {
			color: var(--accent-yellow);
		}

		@media (max-width: 991px) {
			#main-wrapper {
				margin-left: 0;
				padding: 1rem;
			}
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
		<%- include('../partials/alerts') %>

			<%- include('../partials/customerSidebar', { title: 'Dashboard' }) %>

				<div id="main-wrapper">
					<!-- Hero Section -->
					<div class="customer-hero">
						<h1 class="hero-title">Hello, <span>
								<%= currentUser.firstName %>!
							</span></h1>
						<p class="hero-subtitle">Your reliable partner for fuel and roadside assistance. We're keeping
							you moving, no matter where you are.</p>
						<div class="mt-4">
							<a href="/customer/request-service" class="btn-yellow">Get Instant Help <i
									class="fas fa-chevron-right ms-2"></i></a>
						</div>
					</div>

					<!-- Quick Action Cards -->
					<h2 class="section-title"><i class="fas fa-grid-2"></i> Fast Lane Actions</h2>
					<div class="quick-actions">
						<a href="/customer/request-service" class="action-card">
							<i class="fas fa-gas-pump action-icon"></i>
							<h3>Fuel Delivery</h3>
							<p>Running low? We'll deliver high-quality fuel to your exact location.</p>
						</a>
						<a href="/customer/request-service" class="action-card">
							<i class="fas fa-screwdriver-wrench action-icon"></i>
							<h3>Mechanic Service</h3>
							<p>Engine trouble or flat tyre? Our expert mechanics are on standby.</p>
						</a>
						<a href="/customer/request-service" class="action-card">
							<i class="fas fa-car-battery action-icon"></i>
							<h3>Emergency Aid</h3>
							<p>Jump-starts, lockouts, and emergency towing available 24/7.</p>
						</a>
					</div>

					<!-- Pricing Section -->
					<div class="d-flex justify-content-between align-items-center mb-4">
						<h2 class="section-title mb-0"><i class="fas fa-money-bill-transfer"></i> Service Pricing</h2>
						<div class="category-tabs">
							<button class="category-tab active" data-category="roadside">Roadside Aid</button>
							<button class="category-tab" data-category="fuel">Fuel Services</button>
						</div>
					</div>

					<!-- Roadside Assistance Cards -->
					<div class="row g-4 pricing-grid" id="roadside-cards">
						<div class="col-lg-4 col-md-6">
							<div class="price-card modern-card">
								<div class="price-header text-dark">
									<div class="price-name">Jump Start</div>
									<div class="price-amount">₹1000</div>
								</div>
								<div class="price-body">
									<div class="price-feature"><i class="fas fa-check-circle"></i> Rapid Response Under
										30m</div>
									<div class="price-feature"><i class="fas fa-check-circle"></i> Expert Technician
									</div>
									<div class="price-feature"><i class="fas fa-check-circle"></i> Basic Battery Health
										Check</div>
								</div>
							</div>
						</div>
						<div class="col-lg-4 col-md-6">
							<div class="price-card modern-card">
								<div class="price-header text-dark">
									<div class="price-name">Tyre Repair</div>
									<div class="price-amount">₹2700</div>
								</div>
								<div class="price-body">
									<div class="price-feature"><i class="fas fa-check-circle"></i> On-site Repair /
										Replacement</div>
									<div class="price-feature"><i class="fas fa-check-circle"></i> All Tools Provided
									</div>
									<div class="price-feature"><i class="fas fa-check-circle"></i> Pressure Calibration
									</div>
								</div>
							</div>
						</div>
						<div class="col-lg-4 col-md-6">
							<div class="price-card modern-card">
								<div class="price-header text-dark">
									<div class="price-name">Standard Towing</div>
									<div class="price-amount">₹4200</div>
								</div>
								<div class="price-body">
									<div class="price-feature"><i class="fas fa-check-circle"></i> Flatbed Towing
										Available</div>
									<div class="price-feature"><i class="fas fa-check-circle"></i> Safe Handling
										Guarantee</div>
									<div class="price-feature"><i class="fas fa-check-circle"></i> Up to 15km Base
										Distance</div>
								</div>
							</div>
						</div>
					</div>

					<!-- Fuel Service Cards (Hidden) -->
					<div class="row g-4 pricing-grid" id="fuel-cards" style="display: none;">
						<div class="col-lg-4 col-md-6">
							<div class="price-card modern-card">
								<div class="price-header text-dark">
									<div class="price-name">Small - 500ml</div>
									<div class="price-amount">₹75</div>
								</div>
								<div class="price-body">
									<div class="price-feature"><i class="fas fa-check-circle"></i> Emergency Supply
									</div>
									<div class="price-feature"><i class="fas fa-check-circle"></i> Sealed Container
									</div>
								</div>
							</div>
						</div>
						<div class="col-lg-4 col-md-6">
							<div class="price-card modern-card">
								<div class="price-header text-dark">
									<div class="price-name">Standard - 1L</div>
									<div class="price-amount">₹120</div>
								</div>
								<div class="price-body">
									<div class="price-feature"><i class="fas fa-check-circle"></i> Accurate Measurement
									</div>
									<div class="price-feature"><i class="fas fa-check-circle"></i> Fast Delivery</div>
								</div>
							</div>
						</div>
						<div class="col-lg-4 col-md-6">
							<div class="price-card modern-card">
								<div class="price-header text-dark">
									<div class="price-name">Pro - 5L</div>
									<div class="price-amount">₹550</div>
								</div>
								<div class="price-body">
									<div class="price-feature"><i class="fas fa-check-circle"></i> Full Refill Potential
									</div>
									<div class="price-feature"><i class="fas fa-check-circle"></i> Premium Grade Fuel
									</div>
								</div>
							</div>
						</div>
					</div>

					<!-- Process Guide -->
					<div class="mt-5 pt-4">
						<h2 class="section-title text-center"><i class="fas fa-road"></i> Three Steps To Success</h2>
						<div class="row g-4 mt-2">
							<div class="col-md-4 text-center">
								<div class="modern-card">
									<img src="/assets/images/mech.png" class="img-fluid mb-3" style="max-height: 80px;"
										alt="Step 1">
									<h4>Request</h4>
									<p>Tell us what you need and where you are via our easy interface.</p>
								</div>
							</div>
							<div class="col-md-4 text-center">
								<div class="modern-card">
									<img src="/assets/images/phone.png" class="img-fluid mb-3" style="max-height: 80px;"
										alt="Step 2">
									<h4>Track</h4>
									<p>Watch our partner arrive in real-time or get SMS updates.</p>
								</div>
							</div>
							<div class="col-md-4 text-center">
								<div class="modern-card">
									<img src="/assets/images/payy.png" class="img-fluid mb-3" style="max-height: 80px;"
										alt="Step 3">
									<h4>Complete</h4>
									<p>Confirm the service, pay securely, and continue your journey.</p>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Scripts -->
				<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
				<script>
					document.addEventListener('DOMContentLoaded', function () {
						const tabs = document.querySelectorAll('.category-tab');
						const roadsideCards = document.getElementById('roadside-cards');
						const fuelCards = document.getElementById('fuel-cards');

						tabs.forEach(tab => {
							tab.addEventListener('click', () => {
								tabs.forEach(t => t.classList.remove('active'));
								tab.classList.add('active');

								if (tab.dataset.category === 'roadside') {
									roadsideCards.style.display = 'flex';
									fuelCards.style.display = 'none';
								} else {
									roadsideCards.style.display = 'none';
									fuelCards.style.display = 'flex';
								}
							});
						});
					});
				</script>
</body>

</html>