<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Mechanic Profile | RoadAid Admin</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.page-header {
			margin-bottom: 3rem;
			border-left: 5px solid var(--accent-yellow);
			padding-left: 1.5rem;
			display: flex;
			justify-content: space-between;
			align-items: center;
		}

		.page-header h2 {
			font-weight: 800;
			margin: 0;
			text-transform: uppercase;
			letter-spacing: 1px;
		}

		.profile-hero-card {
			background: var(--card-bg);
			border-radius: 40px;
			overflow: hidden;
			border: 1px solid #333;
			color: var(--text-dark);
			margin-bottom: 3rem;
		}

		.hero-banner {
			height: 200px;
			background: linear-gradient(135deg, #111 0%, #222 100%);
			position: relative;
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.hero-banner::after {
			content: "\f7d9";
			/* tools icon */
			font-family: "Font Awesome 6 Free";
			font-weight: 900;
			font-size: 15rem;
			position: absolute;
			bottom: -50px;
			right: -20px;
			opacity: 0.03;
			color: var(--accent-yellow);
		}

		.profile-overlap-avatar {
			width: 150px;
			height: 150px;
			background: #fff;
			border: 8px solid var(--card-bg);
			border-radius: 40px;
			position: absolute;
			bottom: -75px;
			left: 3rem;
			display: flex;
			align-items: center;
			justify-content: center;
			box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
			font-size: 4rem;
			color: #111;
		}

		.hero-details {
			padding: 5rem 3rem 3rem;
			display: flex;
			justify-content: space-between;
			align-items: flex-end;
		}

		.hero-meta h3 {
			font-weight: 800;
			margin: 0;
			font-size: 2rem;
			color: #111;
		}

		.role-pill-v {
			background: #f0f0f0;
			padding: 0.4rem 1.25rem;
			border-radius: 50px;
			font-size: 0.75rem;
			font-weight: 800;
			text-transform: uppercase;
			color: #666;
			letter-spacing: 1px;
		}

		.info-matrix {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
			gap: 2rem;
			padding: 0 3rem 3rem;
		}

		.matrix-item {
			display: flex;
			gap: 1.5rem;
			padding: 1.5rem;
			background: #fcfcfc;
			border-radius: 20px;
			border: 1px solid #f0f0f0;
		}

		.matrix-icon {
			width: 45px;
			height: 45px;
			background: #111;
			border-radius: 12px;
			display: flex;
			align-items: center;
			justify-content: center;
			color: var(--accent-yellow);
			font-size: 1rem;
		}

		.matrix-content label {
			display: block;
			font-size: 0.6rem;
			text-transform: uppercase;
			font-weight: 700;
			color: #999;
			margin-bottom: 0.25rem;
		}

		.matrix-content span {
			font-weight: 700;
			color: #333;
			font-size: 0.95rem;
		}

		.action-tray-v {
			padding: 2.5rem 3rem;
			background: #111;
			display: flex;
			justify-content: space-between;
			align-items: center;
		}

		.btn-return-v {
			text-decoration: none;
			color: #888;
			font-weight: 700;
			font-size: 0.8rem;
			text-transform: uppercase;
			display: flex;
			align-items: center;
			gap: 0.75rem;
			transition: var(--transition);
		}

		.btn-return-v:hover {
			color: var(--accent-yellow);
		}

		.btn-action-primary-v {
			background: var(--accent-yellow);
			color: #000;
			padding: 0.8rem 2.5rem;
			border-radius: 12px;
			text-decoration: none;
			font-weight: 800;
			text-transform: uppercase;
			font-size: 0.8rem;
			transition: var(--transition);
		}

		.btn-action-primary-v:hover {
			transform: scale(1.05);
			box-shadow: 0 10px 20px rgba(247, 183, 29, 0.3);
		}

		@media (max-width: 991px) {
			#main-wrapper {
				margin-left: 0;
				padding: 1.5rem;
			}

			.hero-details {
				flex-direction: column;
				align-items: flex-start;
				gap: 1.5rem;
			}

			.profile-overlap-avatar {
				left: 1.5rem;
			}

			.hero-details {
				padding: 6rem 1.5rem 2rem;
			}

			.info-matrix {
				padding: 0 1.5rem 2rem;
			}
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
		<%- include('../partials/adminSidebar', { title: 'Mechanic Profile' }) %>

			<div id="main-wrapper">
				<div class="page-header">
					<h2>Partner <span>Profile</span></h2>
					<a href="/admin/mechanics" class="btn-return-v"><i class="fas fa-angles-left"></i> Registry</a>
				</div>

				<%- include('../partials/alerts') %>

					<div class="profile-hero-card">
						<div class="hero-banner">
							<div class="profile-overlap-avatar">
								<i class="fas fa-user-gear"></i>
							</div>
						</div>

						<div class="hero-details">
							<div class="hero-meta">
								<span class="role-pill-v">Certified Service Mechanic</span>
								<h3 class="mt-2 text-uppercase">
									<%= mechanic.firstName %>
										<%= mechanic.lastName %>
								</h3>
							</div>
							<div>
								<span class="fw-bold" style="color: #666;"><i class="fas fa-star text-warning me-2"></i>
									<%= mechanic.rating || '5.0' %> Reliability Score
								</span>
							</div>
						</div>

						<div class="info-matrix">
							<div class="matrix-item">
								<div class="matrix-icon"><i class="fas fa-envelope"></i></div>
								<div class="matrix-content">
									<label>Professional Email</label>
									<span>
										<%= mechanic.email %>
									</span>
								</div>
							</div>
							<div class="matrix-item">
								<div class="matrix-icon"><i class="fas fa-phone-volume"></i></div>
								<div class="matrix-content">
									<label>Auth Contact</label>
									<span>+91 <%= mechanic.phone || 'N/A' %></span>
								</div>
							</div>
							<div class="matrix-item" style="grid-column: span 2;">
								<div class="matrix-icon"><i class="fas fa-location-crosshairs"></i></div>
								<div class="matrix-content">
									<label>Registered Operations Base</label>
									<span>
										<%= mechanic.address || 'Operations address not specified' %>
									</span>
								</div>
							</div>
							<div class="matrix-item">
								<div class="matrix-icon"><i class="fas fa-calendar-check"></i></div>
								<div class="matrix-content">
									<label>Joined Network</label>
									<span>
										<%= mechanic.joinedTime ? mechanic.joinedTime.toLocaleString("en-IN", {
											dateStyle: "long" }) : 'N/A' %>
									</span>
								</div>
							</div>
							<div class="matrix-item">
								<div class="matrix-icon"><i class="fas fa-briefcase"></i></div>
								<div class="matrix-content">
									<label>Industry Tenure</label>
									<span>
										<%= mechanic.experience || '3+' %> Years Experience
									</span>
								</div>
							</div>
							<div class="matrix-item">
								<div class="matrix-icon"><i class="fas fa-toggle-on"></i></div>
								<div class="matrix-content">
									<label>Availability status</label>
									<span class="text-success">
										<%= mechanic.availability || 'Available for Dispatch' %>
									</span>
								</div>
							</div>
							<div class="matrix-item">
								<div class="matrix-icon"><i class="fas fa-shield-check"></i></div>
								<div class="matrix-content">
									<label>Trust Level</label>
									<span class="text-primary"><i class="fas fa-certificate me-2"></i>Verified
										Professional</span>
								</div>
							</div>
						</div>

						<div class="action-tray-v">
							<a href="/admin/mechanics" class="btn-return-v">
								<i class="fas fa-arrow-left"></i> Back to Fleet Overview
							</a>
							<a href="mailto:<%= mechanic.email %>" class="btn-action-primary-v">
								Direct Correspondence
							</a>
						</div>
					</div>
			</div>

			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>