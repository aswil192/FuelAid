<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Financial Overview | RoadAid Admin</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.page-header {
			margin-bottom: 3rem;
			border-left: 5px solid var(--accent-yellow);
			padding-left: 1.5rem;
		}

		.page-header h2 {
			font-weight: 800;
			margin: 0;
			text-transform: uppercase;
			letter-spacing: 1px;
		}

		/* Financial Stats */
		.revenue-dashboard-grid {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: 1.5rem;
			margin-bottom: 3rem;
		}

		.fin-stat-card {
			background: var(--card-bg);
			border-radius: 25px;
			padding: 2rem;
			border: 1px solid #333;
			transition: var(--transition);
		}

		.fin-stat-card:hover {
			transform: translateY(-5px);
			border-color: var(--accent-yellow);
		}

		.fin-stat-card .icon-box {
			width: 50px;
			height: 50px;
			background: #111;
			border-radius: 12px;
			display: flex;
			align-items: center;
			justify-content: center;
			margin-bottom: 1.5rem;
			color: var(--accent-yellow);
			font-size: 1.25rem;
		}

		.fin-stat-card .value {
			display: block;
			font-size: 1.5rem;
			font-weight: 800;
			color: #111;
			margin-bottom: 0.25rem;
		}

		.fin-stat-card .label {
			font-size: 0.7rem;
			text-transform: uppercase;
			font-weight: 700;
			color: #888;
			letter-spacing: 1px;
		}

		/* Transactions Table */
		.transactions-panel {
			background: var(--card-bg);
			border-radius: 30px;
			border: 1px solid #333;
			overflow: hidden;
		}

		.panel-header {
			padding: 2rem;
			border-bottom: 1px solid #eee;
			display: flex;
			justify-content: space-between;
			align-items: center;
			background: #fcfcfc;
		}

		.panel-header h5 {
			margin: 0;
			font-weight: 800;
			color: #111;
			display: flex;
			align-items: center;
			gap: 0.75rem;
			font-size: 1rem;
			text-transform: uppercase;
		}

		.table-responsive {
			padding: 0;
		}

		.premium-data-table {
			width: 100%;
			border-collapse: collapse;
		}

		.premium-data-table th {
			padding: 1.5rem 2rem;
			background: #111;
			color: var(--accent-yellow);
			font-size: 0.7rem;
			text-transform: uppercase;
			font-weight: 800;
			letter-spacing: 1px;
			text-align: left;
		}

		.premium-data-table td {
			padding: 1.5rem 2rem;
			border-bottom: 1px solid #f0f0f0;
			color: #111;
			font-size: 0.9rem;
			font-weight: 600;
		}

		.premium-data-table tr:last-child td {
			border-bottom: none;
		}

		.premium-data-table tr:hover {
			background: #f9f9f9;
		}

		/* User Item */
		.user-item-mini {
			display: flex;
			align-items: center;
			gap: 1rem;
		}

		.user-item-mini .avatar-v {
			width: 35px;
			height: 35px;
			background: #eee;
			border-radius: 10px;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 0.8rem;
			font-weight: 800;
			color: #111;
		}

		/* Statuses */
		.stat-badge-v {
			padding: 0.3rem 0.8rem;
			border-radius: 50px;
			font-size: 0.65rem;
			font-weight: 800;
			text-transform: uppercase;
		}

		.stat-completed {
			background: #e8f5e9;
			color: #2e7d32;
		}

		.stat-pending {
			background: #fff8e1;
			color: #f57f17;
		}

		.stat-failed {
			background: #ffebee;
			color: #c62828;
		}

		.service-category-tag {
			color: #888;
			font-size: 0.75rem;
			font-weight: 700;
			text-transform: uppercase;
		}

		@media (max-width: 1200px) {
			.revenue-dashboard-grid {
				grid-template-columns: repeat(2, 1fr);
			}
		}

		@media (max-width: 991px) {
			#main-wrapper {
				margin-left: 0;
				padding: 1.5rem;
			}

			.revenue-dashboard-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
		<%- include('../partials/adminSidebar', { title: 'Financial Oversight' }) %>

			<div id="main-wrapper">
				<div class="page-header">
					<h2>Financial <span>Oversight</span></h2>
					<p class="text-muted mb-0">Monitor platform revenue, processed payments, and net profitability.</p>
				</div>

				<%- include('../partials/alerts') %>

					<!-- Dashboard Stats -->
					<div class="revenue-dashboard-grid">
						<div class="fin-stat-card">
							<div class="icon-box"><i class="fas fa-sack-dollar"></i></div>
							<span class="value">₹<%= totalRevenue.toLocaleString('en-IN') %></span>
							<span class="label">Gross Revenue</span>
						</div>
						<div class="fin-stat-card">
							<div class="icon-box"><i class="fas fa-check-double"></i></div>
							<span class="value">
								<%= completedPayments %>
							</span>
							<span class="label">Successful Trans.</span>
						</div>
						<div class="fin-stat-card">
							<div class="icon-box"><i class="fas fa-hourglass-half"></i></div>
							<span class="value">
								<%= pendingPayments %>
							</span>
							<span class="label">Awaiting Settlement</span>
						</div>
						<div class="fin-stat-card">
							<div class="icon-box"><i class="fas fa-wallet"></i></div>
							<span class="value">₹<%= remainingRevenue.toLocaleString('en-IN') %></span>
							<span class="label">Platform Profit</span>
						</div>
					</div>

					<!-- Recent Transactions -->
					<div class="transactions-panel">
						<div class="panel-header">
							<h5><i class="fas fa-receipt"></i> Transaction Ledger</h5>
						</div>

						<% if (payments.length===0) { %>
							<div class="text-center py-5">
								<i class="fas fa-file-invoice-dollar mb-3" style="font-size: 3rem; color: #eee;"></i>
								<h5 class="text-muted">No records found</h5>
							</div>
							<% } else { %>
								<div class="table-responsive">
									<table class="premium-data-table">
										<thead>
											<tr>
												<th>Client Identity</th>
												<th>Service Partner</th>
												<th>Assistance Type</th>
												<th>Settlement</th>
												<th>Transaction Status</th>
												<th>Recorded Date</th>
											</tr>
										</thead>
										<tbody>
											<% payments.forEach(payment=> { %>
												<tr>
													<td>
														<div class="user-item-mini">
															<div class="avatar-v">
																<%= payment.customer?.firstName.charAt(0) %>
															</div>
															<div>
																<div>
																	<%= payment.customer?.firstName %>
																		<%= payment.customer?.lastName %>
																</div>
																<div class="small text-muted" style="font-size: 11px;">
																	ID: #<%= payment.customer?._id.toString().slice(-4)
																		%>
																</div>
															</div>
														</div>
													</td>
													<td>
														<div class="user-item-mini">
															<div class="avatar-v"
																style="background: #111; color: var(--accent-yellow);">
																<%= payment.provider?.firstName.charAt(0) %>
															</div>
															<div>
																<div>
																	<%= payment.provider?.firstName %>
																</div>
																<div class="small text-muted" style="font-size: 11px;">
																	<%= payment.providerType==='mechanic' ? 'Mechanic'
																		: 'Fuel Op' %>
																</div>
															</div>
														</div>
													</td>
													<td>
														<span class="service-category-tag">
															<%= payment.serviceRequest?.serviceCategory || 'Generic' %>
														</span>
													</td>
													<td>
														<span class="fw-bold">₹<%= payment.amount %></span>
													</td>
													<td>
														<span
															class="stat-badge-v <%= payment.status === 'completed' ? 'stat-completed' : (payment.status === 'pending' ? 'stat-pending' : 'stat-failed') %>">
															<%= payment.status %>
														</span>
													</td>
													<td>
														<span class="text-muted" style="font-size: 12px;">
															<%= payment.paidAt ? new
																Date(payment.paidAt).toLocaleDateString('en-IN')
																: 'Awaiting' %>
														</span>
													</td>
												</tr>
												<% }) %>
										</tbody>
									</table>
								</div>
								<% } %>
					</div>
			</div>

			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>