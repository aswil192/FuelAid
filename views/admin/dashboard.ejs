<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Admin Dashboard | RoadAid</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.admin-hero {
			background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.85)), url('/assets/images/admin/admin_banner.png');
			background-size: cover;
			background-position: center;
			border-radius: 30px;
			padding: 4rem;
			margin-bottom: 3rem;
			border: 1px solid #333;
			display: flex;
			justify-content: space-between;
			align-items: center;
			box-shadow: 0 20px 50px rgba(0,0,0,0.6);
			position: relative;
			overflow: hidden;
		}

		.hero-text h1 {
			font-weight: 800;
			font-size: 3.5rem;
			margin-bottom: 0.5rem;
			letter-spacing: -1px;
			text-shadow: 0 4px 15px rgba(0,0,0,0.5);
		}

		.hero-text p {
			color: rgba(255,255,255,0.7);
			font-weight: 500;
			font-size: 1.1rem;
		}

		.clock-box {
			background: rgba(0, 0, 0, 0.4);
			backdrop-filter: blur(10px);
			border: 1px solid rgba(255,255,255,0.1);
			padding: 2rem;
			border-radius: 25px;
			text-align: right;
			box-shadow: 0 20px 40px rgba(0,0,0,0.3);
		}

		.clock-time {
			font-size: 2.5rem;
			font-weight: 800;
			color: var(--accent-yellow);
			line-height: 1;
		}

		.clock-date {
			font-size: 0.9rem;
			text-transform: uppercase;
			letter-spacing: 2px;
			font-weight: 600;
			color: #888;
		}

		.stat-grid-premium {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
			gap: 2rem;
			margin-bottom: 3rem;
		}

		.stat-card-mega {
			background: var(--card-bg);
			border-radius: 25px;
			padding: 2rem;
			color: var(--text-dark);
			border: 1px solid #333;
			box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
			transition: var(--transition);
			position: relative;
			overflow: hidden;
		}

		.stat-card-mega:hover {
			transform: translateY(-10px);
			box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
		}

		.stat-card-mega i {
			font-size: 3rem;
			opacity: 0.1;
			position: absolute;
			right: -10px;
			bottom: -10px;
			color: var(--primary-bg);
		}

		.stat-label-mini {
			display: block;
			font-size: 0.75rem;
			text-transform: uppercase;
			font-weight: 700;
			color: #888;
			margin-bottom: 0.5rem;
		}

		.stat-number-mega {
			font-size: 3rem;
			font-weight: 800;
			color: #111;
			line-height: 1;
			margin-bottom: 0.5rem;
		}

		.stat-footer-text {
			font-size: 0.8rem;
			font-weight: 600;
			color: #555;
		}

		.action-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
			gap: 1.5rem;
		}

		.action-tile-premium {
			background: #1a1a1a;
			border-radius: 20px;
			padding: 2rem;
			text-align: center;
			text-decoration: none;
			border: 1px solid #333;
			transition: var(--transition);
		}

		.action-tile-premium i {
			font-size: 2rem;
			color: var(--accent-yellow);
			margin-bottom: 1rem;
			display: block;
		}

		.action-tile-premium span {
			color: #fff;
			font-weight: 700;
			font-size: 0.9rem;
			text-transform: uppercase;
		}

		.action-tile-premium:hover {
			background: var(--accent-yellow);
			border-color: var(--accent-yellow);
			transform: translateY(-5px);
		}

		.action-tile-premium:hover i,
		.action-tile-premium:hover span {
			color: #000;
		}

		.system-insight-card {
			background: #111;
			border-radius: 20px;
			padding: 2rem;
			border: 1px solid #333;
			margin-top: 3rem;
		}

		.insight-header {
			display: flex;
			justify-content: space-between;
			align-items: center;
			margin-bottom: 2rem;
			border-bottom: 1px solid #222;
			padding-bottom: 1rem;
		}

		.insight-header h4 {
			font-weight: 800;
			color: var(--accent-yellow);
			margin: 0;
		}

		.insight-row {
			display: flex;
			justify-content: space-between;
			padding: 1rem 0;
			border-bottom: 1px dashed #222;
		}

		.insight-label {
			color: #888;
			font-weight: 600;
		}

		.insight-value {
			color: #fff;
			font-weight: 800;
		}

		@media (max-width: 991px) {
			#main-wrapper {
				margin-left: 0;
				padding: 1.5rem;
			}

			.admin-hero {
				flex-direction: column;
				text-align: center;
			}

			.clock-box {
				border-left: none;
				border-top: 2px solid var(--accent-yellow);
				padding-left: 0;
				padding-top: 2rem;
				margin-top: 2rem;
				width: 100%;
				text-align: center;
			}
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
		<%- include('../partials/adminSidebar', { title: 'Dashboard' }) %>

			<div id="main-wrapper">
				<%- include('../partials/alerts') %>

					<!-- Hero Section -->
					<div class="admin-hero">
						<div class="hero-text">
							<h1>Control <span>Center</span></h1>
							<p>Welcome back, Admin. System is running at optimal capacity.</p>
						</div>
						<div class="clock-box">
							<div class="clock-time" id="live-time">00:00:00</div>
							<div class="clock-date" id="live-date">Loading date...</div>
						</div>
					</div>

					<!-- Metric Section -->
					<div class="stat-grid-premium">
						<div class="stat-card-mega">
							<i class="fas fa-users"></i>
							<span class="stat-label-mini">Total Customers</span>
							<div class="stat-number-mega">
								<%= numcustomers %>
							</div>
							<div class="stat-footer-text"><i class="fas fa-arrow-up text-success me-1"></i> 12% Growth
								this month</div>
						</div>
						<div class="stat-card-mega">
							<i class="fas fa-wrench"></i>
							<span class="stat-label-mini">Verified Mechanics</span>
							<div class="stat-number-mega">
								<%= nummechanics %>
							</div>
							<div class="stat-footer-text">Across 8 major service zones</div>
						</div>
						<div class="stat-card-mega">
							<i class="fas fa-motorcycle"></i>
							<span class="stat-label-mini">Delivery Fleet</span>
							<div class="stat-number-mega">
								<%= numfueldeliveryboy %>
							</div>
							<div class="stat-footer-text text-success"><i class="fas fa-check-circle me-1"></i> Fleet
								Status: Active</div>
						</div>
						<div class="stat-card-mega">
							<i class="fas fa-clock"></i>
							<span class="stat-label-mini">Pending Deliveries</span>
							<div class="stat-number-mega text-warning">
								<%= numPendingDonations %>
							</div>
							<div class="stat-footer-text">Requires immediate assignment</div>
						</div>
					</div>

					<!-- Quick Actions Grid -->
					<h4 class="mb-4 fw-bold text-uppercase" style="letter-spacing: 2px;">Strategic <span>Actions</span>
					</h4>
					<div class="action-grid">
						<a href="/admin/verify-users" class="action-tile-premium">
							<i class="fas fa-user-shield"></i>
							<span>Approve Users</span>
						</a>
						<a href="/admin/donations/pending" class="action-tile-premium">
							<i class="fas fa-truck-loading"></i>
							<span>Dispatch Fleet</span>
						</a>
						<a href="/admin/fuelrequests" class="action-tile-premium">
							<i class="fas fa-gas-pump"></i>
							<span>Fuel Logistics</span>
						</a>
						<a href="/admin/salaries" class="action-tile-premium">
							<i class="fas fa-wallet"></i>
							<span>Payroll</span>
						</a>
						<a href="/admin/payments" class="action-tile-premium">
							<i class="fas fa-chart-line"></i>
							<span>Revenue</span>
						</a>
					</div>

					<!-- System Insight -->
					<div class="row">
						<div class="col-lg-8">
							<div class="system-insight-card">
								<div class="insight-header">
									<h4>Live System Metrics</h4>
									<span class="badge bg-success rounded-pill px-3">Stable</span>
								</div>
								<div class="insight-row">
									<span class="insight-label">Platform Uptime</span>
									<span class="insight-value text-success">99.9%</span>
								</div>
								<div class="insight-row">
									<span class="insight-label">Avg. Response Time</span>
									<span class="insight-value">4.2 mins</span>
								</div>
								<div class="insight-row">
									<span class="insight-label">Total Verified Network</span>
									<span class="insight-value">
										<%= numcustomers + nummechanics + numfueldeliveryboy %> Users
									</span>
								</div>
								<div class="insight-row">
									<span class="insight-label">Completion Rate</span>
									<span class="insight-value text-warning">
										<%= numCollectedDonations> 0 ? Math.round((numCollectedDonations /
											(numCollectedDonations + numPendingDonations)) * 100) : 0 %>%
									</span>
								</div>
							</div>
						</div>
						<div class="col-lg-4">
							<div class="system-insight-card h-100" style="background: var(--accent-yellow);">
								<h4 class="text-dark mb-4">Command Tips</h4>
								<p class="text-dark fw-bold mb-4">"Efficiency is not just about speed, it's about the
									quality of every rescue."</p>
								<div class="bg-dark p-3 rounded-3 text-white small">
									<i class="fas fa-lightbulb text-warning me-2"></i> Monitor pending requests every 30
									minutes for zero-lag dispatch.
								</div>
							</div>
						</div>
					</div>
			</div>

			<!-- Scripts -->
			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
			<script>
				function updateClock() {
					const now = new Date();
					const time = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
					const date = now.toLocaleDateString(undefined, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
					document.getElementById('live-time').textContent = time;
					document.getElementById('live-date').textContent = date;
				}
				setInterval(updateClock, 1000);
				updateClock();
			</script>
</body>

</html>