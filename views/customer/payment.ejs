<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Secure Checkout | FuelAid</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.checkout-container {
			width: 100%;
			max-width: 900px;
			display: grid;
			grid-template-columns: 1fr 1.2fr;
			background: var(--card-bg);
			border-radius: 30px;
			overflow: hidden;
			box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);
			border: 1px solid #333;
		}

		/* Left Side: Order Summary */
		.order-summary {
			background: #111;
			padding: 3rem;
			color: #fff;
			border-right: 1px solid #222;
		}

		.order-summary h3 {
			font-weight: 800;
			text-transform: uppercase;
			font-size: 1.25rem;
			margin-bottom: 2rem;
			color: var(--accent-yellow);
			display: flex;
			align-items: center;
			gap: 0.75rem;
		}

		.summary-item {
			display: flex;
			justify-content: space-between;
			margin-bottom: 1rem;
			font-size: 0.9rem;
			color: #888;
		}

		.summary-item.total {
			margin-top: 2rem;
			padding-top: 2rem;
			border-top: 1px solid #222;
			color: #fff;
			font-weight: 800;
			font-size: 1.5rem;
		}

		.provider-tiny-card {
			background: #1a1a1a;
			padding: 1rem;
			border-radius: 15px;
			margin-top: 2rem;
			display: flex;
			align-items: center;
			gap: 1rem;
		}

		.provider-tiny-card img {
			width: 45px;
			height: 45px;
			border-radius: 50%;
			border: 2px solid var(--accent-yellow);
		}

		/* Right Side: Payment Form */
		.payment-form-section {
			padding: 3rem;
			color: var(--text-dark);
		}

		.payment-form-section h4 {
			font-weight: 800;
			margin-bottom: 2rem;
			color: #111;
		}

		.payment-methods-grid {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 1rem;
			margin-bottom: 2rem;
		}

		.method-tile {
			border: 2px solid #eee;
			border-radius: 15px;
			padding: 1.5rem;
			text-align: center;
			cursor: pointer;
			transition: var(--transition);
		}

		.method-tile i {
			font-size: 1.5rem;
			margin-bottom: 0.5rem;
			display: block;
			color: #888;
		}

		.method-tile span {
			font-weight: 700;
			font-size: 0.8rem;
			text-transform: uppercase;
		}

		.method-tile:hover {
			border-color: var(--accent-yellow);
			background: #fcf8e8;
		}

		.method-tile.active {
			border-color: var(--accent-yellow);
			background: #fcf8e8;
			box-shadow: 0 5px 15px rgba(247, 183, 29, 0.1);
		}

		.method-tile.active i {
			color: var(--accent-yellow);
		}

		.method-tile input {
			display: none;
		}

		.input-group-custom {
			margin-top: 1.5rem;
			animation: fadeIn 0.4s ease;
		}

		@keyframes fadeIn {
			from {
				opacity: 0;
				transform: translateY(10px);
			}

			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		.form-control-custom {
			width: 100%;
			padding: 1rem;
			border: 2px solid #eee;
			border-radius: 12px;
			font-weight: 600;
		}

		.form-control-custom:focus {
			border-color: var(--accent-yellow);
			outline: none;
		}

		.pay-now-btn {
			width: 100%;
			background: var(--accent-yellow);
			color: #000;
			border: none;
			padding: 1.2rem;
			border-radius: 50px;
			font-weight: 800;
			text-transform: uppercase;
			letter-spacing: 1px;
			margin-top: 2rem;
			transition: var(--transition);
			box-shadow: 0 10px 20px rgba(247, 183, 29, 0.2);
		}

		.pay-now-btn:hover {
			transform: translateY(-3px);
			box-shadow: 0 15px 30px rgba(247, 183, 29, 0.4);
		}

		.secure-footer {
			margin-top: 1.5rem;
			text-align: center;
			font-size: 0.75rem;
			color: #999;
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 0.5rem;
		}

		@media (max-width: 991px) {
			#main-wrapper {
				margin-left: 0;
				padding: 1.5rem;
			}

			.checkout-container {
				grid-template-columns: 1fr;
			}

			.order-summary {
				padding: 2rem;
			}
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
		<%- include('../partials/customerSidebar', { title: 'Checkout' }) %>

			<div id="main-wrapper">
				<div class="checkout-container">
					<!-- Left: Summary -->
					<div class="order-summary">
						<h3><i class="fas fa-shopping-bag"></i> Order Summary</h3>

						<div class="summary-item">
							<span>Service Type</span>
							<span class="text-white fw-bold">
								<%= service.serviceCategory.toUpperCase() %>
							</span>
						</div>

						<div class="mb-4">
							<label class="small text-muted fw-bold text-uppercase d-block mb-2">Itemized
								Services</label>
							<% service.subServices.forEach(sub=> { %>
								<div class="summary-item mb-1">
									<span><i class="fas fa-check-circle me-2 text-warning small"></i>
										<%= sub %>
									</span>
								</div>
								<% }) %>
						</div>

						<div class="summary-item">
							<span>Service Date</span>
							<span class="text-white">
								<%= service.completedAt ? new Date(service.completedAt).toLocaleDateString() : new
									Date(service.createdAt).toLocaleDateString() %>
							</span>
						</div>

						<div class="summary-item total">
							<span>Total Amount</span>
							<span class="text-warning">₹<%= service.totalAmount || service.baseAmount || 100 %></span>
						</div>

						<% if (provider) { %>
							<div class="provider-tiny-card">
								<img src="<%= provider.profilePic || '/assets/images/default-avatar.png' %>"
									alt="Provider">
								<div>
									<div class="small text-muted fw-bold text-uppercase">Assigned Provider</div>
									<div class="small fw-bold">
										<%= provider.firstName %>
											<%= provider.lastName %>
									</div>
								</div>
							</div>
							<% } %>
					</div>

					<!-- Right: Payment Form -->
					<div class="payment-form-section">
						<h4>Choose Payment Method</h4>

						<form action="/customer/process-payment/<%= service._id %>" method="POST">
							<div class="payment-methods-grid">
								<label class="method-tile active">
									<input type="radio" name="paymentMethod" value="cash" checked>
									<i class="fas fa-money-bill-wave"></i>
									<span>Cash</span>
								</label>

								<label class="method-tile">
									<input type="radio" name="paymentMethod" value="upi">
									<i class="fas fa-mobile-alt"></i>
									<span>UPI</span>
								</label>

								<label class="method-tile">
									<input type="radio" name="paymentMethod" value="card">
									<i class="fas fa-credit-card"></i>
									<span>Card</span>
								</label>

								<label class="method-tile">
									<input type="radio" name="paymentMethod" value="online">
									<i class="fas fa-globe"></i>
									<span>Online</span>
								</label>
							</div>

							<div id="dynamicInput" class="input-group-custom" style="display: none;">
								<label class="small fw-bold text-uppercase mb-2 d-block" id="inputLabel">Transaction
									details</label>
								<input type="text" name="transactionId" class="form-control-custom"
									placeholder="Reference ID">
							</div>

							<button type="submit" class="pay-now-btn">
								Complete Payment <i class="fas fa-arrow-right ms-2"></i>
							</button>

							<div class="secure-footer">
								<i class="fas fa-shield-alt text-success"></i>
								<span>Secure SSL Encrypted Payment</span>
							</div>
						</form>
					</div>
				</div>
			</div>

			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
			<script>
				document.querySelectorAll('.method-tile').forEach(tile => {
					tile.addEventListener('click', function () {
						document.querySelectorAll('.method-tile').forEach(t => t.classList.remove('active'));
						this.classList.add('active');

						const method = this.querySelector('input').value;
						const dynamicBox = document.getElementById('dynamicInput');
						const label = document.getElementById('inputLabel');

						if (method === 'cash') {
							dynamicBox.style.display = 'none';
						} else {
							dynamicBox.style.display = 'block';
							label.textContent = method.toUpperCase() + ' Transaction ID / Reference';
						}
					});
				});
			</script>
</body>

</html>