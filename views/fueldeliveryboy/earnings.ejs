<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Finance Command | FuelAid</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.revenue-hero {
			background: var(--card-bg);
			border-radius: 30px;
			padding: 4rem;
			text-align: center;
			margin-bottom: 3rem;
			border: 1px solid #eee;
			position: relative;
			overflow: hidden;
		}

		.revenue-hero::after {
			content: '\f156';
			font-family: 'Font Awesome 6 Free';
			font-weight: 900;
			position: absolute;
			font-size: 15rem;
			color: rgba(0,0,0,0.03);
			top: -2rem;
			right: -2rem;
		}

		.revenue-amount {
			font-size: 5rem;
			font-weight: 900;
			color: #000;
			margin: 1rem 0;
			letter-spacing: -2px;
		}

		.finance-tile {
			background: #fff;
			border-radius: 20px;
			padding: 2rem;
			border: 1px solid #eee;
			text-align: center;
			transition: var(--transition);
		}

		.finance-tile:hover { transform: translateY(-10px); }

		.finance-icon {
			width: 60px;
			height: 60px;
			background: #f8f9fa;
			border-radius: 15px;
			display: flex;
			align-items: center;
			justify-content: center;
			margin: 0 auto 1.5rem;
			color: var(--accent-yellow);
			font-size: 1.5rem;
		}

		.ledger-card {
			background: #fff;
			border-radius: 25px;
			border: 1px solid #eee;
			overflow: hidden;
		}

		.ledger-header {
			padding: 2rem;
			border-bottom: 2px solid #f8f9fa;
			display: flex;
			justify-content: space-between;
			align-items: center;
		}

		.credit-entry {
			padding: 1.5rem 2rem;
			display: flex;
			justify-content: space-between;
			align-items: center;
			border-bottom: 1px solid #f8f9fa;
			transition: var(--transition);
		}

		.credit-entry:hover { background: rgba(0,0,0,0.01); }

		.intel-manual {
			background: #111;
			color: #fff;
			border-radius: 25px;
			padding: 3rem;
			margin-top: 3rem;
		}

		@media (max-width: 991px) {
			#main-wrapper { margin-left: 0; padding: 1.5rem; }
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
	<%- include('../partials/fuelSidebar') %>

	<div id="main-wrapper">
		<%- include('../partials/alerts') %>

		<div class="mb-5">
			<h1 class="hero-title mb-0">Finance <span>Command</span></h1>
			<p class="text-muted">Secure visibility of your fuel delivery revenue and tactical earnings.</p>
		</div>

		<div class="revenue-hero">
			<span class="label-premium">Operational Credits Pending</span>
			<div class="revenue-amount">₹<%= (currentUser.pendingEarnings || 0).toLocaleString('en-IN') %></div>
			<p class="text-muted fw-700 text-uppercase letter-spacing-1 small">Validated & Awaiting Disbursement</p>
			<button class="btn-yellow px-5 mt-3">Sync Wallet</button>
		</div>

		<div class="row g-4 mb-5">
			<div class="col-md-4">
				<div class="finance-tile">
					<div class="finance-icon"><i class="fas fa-vault"></i></div>
					<h3 class="fw-800 text-dark">₹<%= (currentUser.totalEarnings || 0).toLocaleString('en-IN') %></h3>
					<p class="text-muted small fw-700 text-uppercase">Cumulative Revenue</p>
				</div>
			</div>
			<div class="col-md-4">
				<div class="finance-tile">
					<div class="finance-icon"><i class="fas fa-gas-pump"></i></div>
					<h3 class="fw-800 text-dark"><%= completedJobs %></h3>
					<p class="text-muted small fw-700 text-uppercase">Delivery Count</p>
				</div>
			</div>
			<div class="col-md-4">
				<div class="finance-tile">
					<div class="finance-icon"><i class="fas fa-chart-pie"></i></div>
					<h3 class="fw-800 text-dark"><%= currentUser.commissionRate || 40 %>%</h3>
					<p class="text-muted small fw-700 text-uppercase">Commission Ratio</p>
				</div>
			</div>
		</div>

		<div class="ledger-card">
			<div class="ledger-header">
				<h5 class="fw-800 text-dark mb-0 text-uppercase letter-spacing-1">Payment Chronology</h5>
				<i class="fas fa-receipt text-muted"></i>
			</div>
			<% if (recentPayments.length === 0) { %>
				<div class="p-5 text-center text-muted">
					<i class="fas fa-coins mb-3 d-block" style="font-size: 3rem; opacity: 0.1;"></i>
					<p>No credit events recorded in the current cycle.</p>
				</div>
			<% } else { %>
				<% recentPayments.forEach(payment => { %>
					<div class="credit-entry">
						<div>
							<h6 class="fw-800 text-dark mb-1 text-uppercase small"><%= payment.serviceRequest?.serviceCategory || 'Rapid Fuel Delivery' %></h6>
							<p class="text-muted extra-small fw-600 mb-0"><%= payment.paidAt ? new Date(payment.paidAt).toLocaleDateString() : 'Pending Registry' %></p>
						</div>
						<div class="text-end">
							<h6 class="fw-900 text-success mb-0">+₹<%= Math.round(payment.amount * (currentUser.commissionRate || 40) / 100) %></h6>
							<span class="badge bg-light text-dark extra-small">Verified</span>
						</div>
					</div>
				<% }) %>
			<% } %>
		</div>

		<div class="intel-manual">
			<h5 class="fw-800 text-warning mb-4 text-uppercase letter-spacing-1"><i class="fas fa-shield-halved me-2"></i> Revenue Directives</h5>
			<div class="row g-4">
				<div class="col-md-6">
					<p class="small text-muted"><strong class="text-white">Ratio Allocation:</strong> You are authorized for a <%= currentUser.commissionRate || 40 %>% credit share on every successfully concluded delivery.</p>
					<p class="small text-muted"><strong class="text-white">Credit Trigger:</strong> Revenue entry is triggered immediately upon client-side payment confirmation.</p>
				</div>
				<div class="col-md-6">
					<p class="small text-muted"><strong class="text-white">Registry Sync:</strong> Disbursement cycles are managed by Central Command (HQ Admin).</p>
					<p class="small text-muted"><strong class="text-white">Operational Help:</strong> For cryptography or credit synchronization errors, contact Technical HQ.</p>
				</div>
			</div>
		</div>
	</div>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
	<script src="/assets/js/script.js"></script>
</body>
</html>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p" crossorigin="anonymous"></script>
<script src="/assets/js/script.js"></script>

</body>
</html>
