<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Field History Log | FuelAid</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.history-card {
			background: var(--card-bg);
			border-radius: 25px;
			padding: 2.5rem;
			margin-bottom: 2rem;
			border: 1px solid #eee;
			color: var(--text-dark);
			transition: var(--transition);
			position: relative;
			overflow: hidden;
		}

		.completion-stamp {
			position: absolute;
			top: 2rem;
			right: 2.5rem;
			display: flex;
			align-items: center;
			gap: 0.5rem;
			color: #27ae60;
			font-weight: 800;
			font-size: 0.8rem;
			text-transform: uppercase;
			letter-spacing: 1.5px;
		}

		.history-label {
			font-size: 0.7rem;
			font-weight: 700;
			color: #888;
			text-transform: uppercase;
			letter-spacing: 1px;
			margin-bottom: 0.2rem;
		}

		.history-value {
			font-weight: 700;
			font-size: 0.9rem;
		}

		.note-vault {
			background: #f8f9fa;
			border-radius: 20px;
			padding: 2rem;
			margin-top: 2rem;
			border: 2px dashed #eee;
		}

		.note-vault textarea {
			background: transparent;
			border: 1px solid #ddd;
			border-radius: 12px;
			padding: 1rem;
			width: 100%;
			font-size: 0.9rem;
			margin-bottom: 1rem;
		}

		@media (max-width: 991px) {
			#main-wrapper { margin-left: 0; padding: 1.5rem; }
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
	<%- include('../partials/fuelSidebar') %>

	<div id="main-wrapper">
		<%- include('../partials/alerts') %>

		<div class="mb-5">
			<h1 class="hero-title mb-0">Delivery <span>Archive</span></h1>
			<p class="text-muted">History of successfully executed fuel delivery operations.</p>
		</div>

		<% if (!completedServices || completedServices.length === 0) { %>
			<div class="empty-quest-state text-center p-5">
				<i class="fas fa-archive mb-4" style="font-size: 4rem; color: #333;"></i>
				<h4>Delivery logs are currently empty.</h4>
				<p>History will populate once fuel deliveries are marked as concluded.</p>
			</div>
		<% } else { %>
			<% completedServices.forEach((service, index) => { %>
				<div class="history-card">
					<div class="completion-stamp">
						<i class="fas fa-check-double"></i> Operation Concluded
					</div>

					<h4 class="fw-800 mb-1"><%= service.serviceCategory || 'Rapid Fuel Delivery' %></h4>
					<p class="small text-muted mb-4">Conclusion Hash: #<%= service._id.toString().substring(18).toUpperCase() %></p>

					<div class="row g-4">
						<div class="col-md-3">
							<div class="history-label">Target Client</div>
							<div class="history-value"><%= service.customer.firstName %> <%= service.customer.lastName %></div>
						</div>
						<div class="col-md-3">
							<div class="history-label">Delivery Point</div>
							<div class="history-value"><%= service.address ? service.address.substring(0, 30) + (service.address.length > 30 ? '...' : '') : 'N/A' %></div>
						</div>
						<div class="col-md-3">
							<div class="history-label">Fuel Specs</div>
							<div class="history-value">
								<% if (service.subServices && service.subServices.length > 0) { %>
									<%= service.subServices.join(", ") %>
								<% } else { %>Standard Fuel<% } %>
							</div>
						</div>
						<div class="col-md-3 text-end">
							<div class="history-label">Logged Date</div>
							<div class="history-value text-muted small"><%= new Date(service.completedAt || service.createdAt).toLocaleDateString() %></div>
						</div>
					</div>

					<div class="note-vault">
						<h6 class="fw-800 mb-3"><i class="fas fa-file-signature me-2 text-warning"></i>Field Observations</h6>
						<form class="note-form" data-id="<%= service._id %>">
							<textarea name="fuelNote" rows="3" placeholder="Log details like fuel quantity, vehicle condition, or client feedback..."><%= service.fuelNote || '' %></textarea>
							<button type="submit" class="btn-yellow px-4">Update Log Entries</button>
						</form>
					</div>
				</div>
			<% }); %>
		<% } %>
	</div>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
	<script>
		document.querySelectorAll('.note-form').forEach(form => {
			form.addEventListener('submit', async function (e) {
				e.preventDefault();
				const serviceId = form.dataset.id;
				const note = form.querySelector('textarea').value;
				const btn = form.querySelector('button');
				const originalText = btn.innerHTML;

				try {
					const res = await fetch(`/fueldeliveryboy/note/${serviceId}`, {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ fuelNote: note })
					});
					if (res.ok) {
						btn.innerHTML = '<i class="fas fa-check"></i> Synchronized';
						btn.style.background = '#27ae60';
						btn.style.color = '#fff';
						setTimeout(() => {
							btn.innerHTML = originalText;
							btn.style.background = '';
							btn.style.color = '';
						}, 2000);
					} else {
						alert('Failed to sync log.');
					}
				} catch (err) {
					console.error(err);
					alert('Connection error during sync.');
				}
			});
		});
	</script>
</body>
</html>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/assets/js/script.js"></script>

<script>
	async function saveNote(serviceId) {
		const noteText = document.getElementById(`note-${serviceId}`).value;
		
		try {
			const response = await fetch(`/fueldeliveryboy/note/${serviceId}`, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json'
				},
				body: JSON.stringify({ fuelNote: noteText })
			});

			if (response.ok) {
				// Show success feedback
				const btn = event.target;
				const originalText = btn.innerHTML;
				btn.innerHTML = '<i class="fas fa-check"></i> Saved!';
				btn.style.background = 'linear-gradient(135deg, #27ae60 0%, #27ae60 100%)';
				
				setTimeout(() => {
					btn.innerHTML = originalText;
					btn.style.background = 'linear-gradient(135deg, #27ae60 0%, #2ecc71 100%)';
				}, 2000);
			} else {
				alert('Failed to save note. Please try again.');
			}
		} catch (err) {
			console.error('Error saving note:', err);
			alert('Error saving note. Please try again.');
		}
	}
</script>

</body>
</html>
