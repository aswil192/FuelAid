<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pending Requests | FuelAid</title>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

  <!-- CSS -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
  <link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

  <style>
    body {
      background-color: var(--primary-bg);
      color: var(--text-light);
      font-family: var(--font-main);
    }

    #main-wrapper {
      margin-left: 280px;
      padding: 2.5rem;
      min-height: 100vh;
    }

    .page-header {
      margin-bottom: 3rem;
      border-left: 5px solid var(--accent-yellow);
      padding-left: 1.5rem;
    }

    .page-header h2 {
      font-weight: 800;
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .request-item-card {
      background: var(--card-bg);
      border-radius: var(--border-radius);
      padding: 2rem;
      margin-bottom: 2rem;
      color: var(--text-dark);
      position: relative;
      border: 1px solid #333;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
      transition: var(--transition);
    }

    .request-item-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
    }

    .status-badge-sticky {
      position: absolute;
      top: 2rem;
      right: 2rem;
      background: rgba(247, 183, 29, 0.1);
      color: var(--accent-yellow);
      padding: 0.5rem 1.2rem;
      border-radius: 50px;
      font-weight: 700;
      font-size: 0.8rem;
      text-transform: uppercase;
      border: 1px solid var(--accent-yellow);
    }

    .request-meta {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .meta-group label {
      display: block;
      font-size: 0.75rem;
      text-transform: uppercase;
      font-weight: 700;
      color: #888;
      margin-bottom: 0.25rem;
    }

    .meta-group span {
      font-weight: 600;
      color: #333;
    }

    .sub-services-list {
      background: #f8f9fa;
      padding: 1rem 1.5rem;
      border-radius: 10px;
      margin: 1rem 0;
    }

    .sub-services-list ul {
      margin: 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .sub-services-list li {
      background: #fff;
      padding: 0.4rem 1rem;
      border-radius: 50px;
      font-size: 0.85rem;
      font-weight: 600;
      border: 1px solid #eee;
      color: #555;
    }

    .vehicle-preview {
      width: 120px;
      height: 120px;
      object-fit: cover;
      border-radius: 12px;
      border: 3px solid #eee;
    }

    .empty-state {
      text-align: center;
      padding: 5rem 2rem;
      background: rgba(255, 255, 255, 0.02);
      border-radius: 20px;
      border: 2px dashed #333;
    }

    .empty-state i {
      font-size: 4rem;
      color: #444;
      margin-bottom: 1.5rem;
    }

    @media (max-width: 991px) {
      #main-wrapper {
        margin-left: 0;
        padding: 1.5rem;
      }
    }
  </style>
</head>

<body class="dashboard-body">
  <%- include('../partials/header') %>
    <%- include('../partials/customerSidebar', { title: 'Pending Requests' }) %>

      <div id="main-wrapper">
        <div class="page-header">
          <h2>Pending <span>Requests</span></h2>
          <p class="text-muted mb-0">Track your active service requests currently awaiting confirmation.</p>
        </div>

        <% if (requestedServices.length===0) { %>
          <div class="empty-state">
            <i class="fas fa-clipboard-list"></i>
            <h3>No Pending Requests</h3>
            <p class="text-muted">You don't have any active service requests at the moment.</p>
            <a href="/customer/request-service" class="btn-yellow mt-3">Request A Service</a>
          </div>
          <% } else { %>
            <div class="requests-list">
              <% requestedServices.forEach(service=> { %>
                <div class="request-item-card">
                  <div class="status-badge-sticky">
                    <i class="fas fa-clock me-1"></i> Requested
                  </div>

                  <div class="row">
                    <div class="col-md-9">
                      <div class="request-meta">
                        <div class="meta-group">
                          <label>Category</label>
                          <span><i
                              class="fas <%= service.serviceCategory === 'fuel' ? 'fa-gas-pump' : 'fa-tools' %> me-2 text-warning"></i>
                            <%= service.serviceCategory %>
                          </span>
                        </div>
                        <div class="meta-group">
                          <label>Requested On</label>
                          <span>
                            <%= service.createdAt.toLocaleString("en-IN", { dateStyle: "medium" , timeStyle: "short" })
                              %>
                          </span>
                        </div>
                        <% if (service.quantity) { %>
                          <div class="meta-group">
                            <label>Quantity</label>
                            <span>
                              <%= service.quantity %> Liters
                            </span>
                          </div>
                          <% } %>
                      </div>

                      <div class="meta-group mb-3">
                        <label>Pick-up Address</label>
                        <span><i class="fas fa-map-marker-alt me-2 text-danger"></i>
                          <%= service.address %>
                        </span>
                      </div>

                      <div class="sub-services-list">
                        <label class="small text-muted fw-bold mb-2 d-block">Sub-services Required:</label>
                        <ul>
                          <% service.subServices.forEach(sub=> { %>
                            <li><i class="fas fa-check me-2 text-success"></i>
                              <%= sub %>
                            </li>
                            <% }) %>
                        </ul>
                      </div>

                      <% if (service.customerToMechanicMsg) { %>
                        <div class="meta-group">
                          <label>Your Message</label>
                          <p class="small text-muted mb-0">"<%= service.customerToMechanicMsg %>"</p>
                        </div>
                        <% } %>
                    </div>

                    <% if (service.vehiclePhotoPath) { %>
                      <div class="col-md-3 text-md-end mt-4 mt-md-0">
                        <label class="small text-muted fw-bold mb-2 d-block">Vehicle Image</label>
                        <img src="/<%= service.vehiclePhotoPath %>" alt="Vehicle" class="vehicle-preview shadow-sm"
                          onclick="window.open(this.src)">
                      </div>
                      <% } %>
                  </div>
                </div>
                <% }) %>
            </div>
            <% } %>
      </div>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>