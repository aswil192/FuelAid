<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Remuneration Hub | RoadAid Admin</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.page-header {
			margin-bottom: 3rem;
			border-left: 5px solid var(--accent-yellow);
			padding-left: 1.5rem;
		}

		.page-header h2 {
			font-weight: 800;
			margin: 0;
			text-transform: uppercase;
			letter-spacing: 1px;
		}

		/* Salary Summary */
		.salary-summary-strip {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 2rem;
			margin-bottom: 3rem;
		}

		.summary-card-v {
			background: #111;
			border-radius: 25px;
			padding: 2rem;
			border: 1px solid #333;
			display: flex;
			align-items: center;
			gap: 2rem;
		}

		.summ-icon {
			width: 60px;
			height: 60px;
			background: #222;
			border-radius: 15px;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 1.5rem;
			color: var(--accent-yellow);
		}

		.summ-content h3 {
			margin: 0;
			font-weight: 800;
			color: #fff;
			font-size: 1.75rem;
		}

		.summ-content span {
			font-size: 0.75rem;
			text-transform: uppercase;
			font-weight: 700;
			color: #666;
			letter-spacing: 1px;
		}

		/* Provider Cards */
		.remuneration-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
			gap: 2rem;
		}

		.payroll-card {
			background: var(--card-bg);
			border-radius: 30px;
			border: 1px solid #333;
			overflow: hidden;
			color: var(--text-dark);
			transition: var(--transition);
		}

		.payroll-card:hover {
			transform: translateY(-5px);
			box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
		}

		.payroll-header {
			padding: 2rem;
			display: flex;
			justify-content: space-between;
			align-items: flex-start;
			background: #fcfcfc;
			border-bottom: 1px solid #f0f0f0;
		}

		.provider-identity {
			display: flex;
			align-items: center;
			gap: 1rem;
		}

		.avatar-payroll {
			width: 50px;
			height: 50px;
			background: #111;
			color: var(--accent-yellow);
			border-radius: 12px;
			display: flex;
			align-items: center;
			justify-content: center;
			font-weight: 800;
			font-size: 1.1rem;
		}

		.provider-identity h6 {
			margin: 0;
			font-weight: 800;
			color: #111;
		}

		.role-tag-v {
			font-size: 0.65rem;
			font-weight: 800;
			text-transform: uppercase;
			color: #888;
		}

		/* Wallet stats */
		.payroll-body {
			padding: 2rem;
		}

		.wallet-stat-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 1.5rem;
			margin-bottom: 2rem;
		}

		.wallet-field {
			padding: 1rem;
			background: #f8f9fa;
			border-radius: 15px;
			border: 1px solid #eee;
		}

		.wallet-field label {
			display: block;
			font-size: 0.6rem;
			text-transform: uppercase;
			font-weight: 700;
			color: #999;
			margin-bottom: 0.25rem;
		}

		.wallet-field span {
			display: block;
			font-size: 1.1rem;
			font-weight: 800;
			color: #111;
		}

		.payroll-footer {
			padding: 1.5rem 2rem;
			background: #111;
			display: flex;
			justify-content: space-between;
			align-items: center;
		}

		.payout-btn-v {
			background: var(--accent-yellow);
			color: #000;
			border: none;
			padding: 0.75rem 1.5rem;
			border-radius: 12px;
			font-weight: 800;
			text-transform: uppercase;
			font-size: 0.75rem;
			transition: var(--transition);
		}

		.payout-btn-v:hover {
			transform: scale(1.05);
		}

		.payout-btn-v:disabled {
			background: #333;
			color: #666;
			cursor: not-allowed;
			transform: none;
		}

		.last-settlement {
			font-size: 0.7rem;
			color: #888;
			font-weight: 600;
		}

		@media (max-width: 991px) {
			#main-wrapper {
				margin-left: 0;
				padding: 1.5rem;
			}

			.salary-summary-strip {
				grid-template-columns: 1fr;
			}
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
		<%- include('../partials/adminSidebar', { title: 'Remuneration Management' }) %>

			<div id="main-wrapper">
				<div class="page-header">
					<h2>Remuneration <span>Hub</span></h2>
					<p class="text-muted mb-0">Disburse service provider earnings and monitor platform payroll cycles.
					</p>
				</div>

				<%- include('../partials/alerts') %>

					<div class="salary-summary-strip">
						<div class="summary-card-v">
							<div class="summ-icon"><i class="fas fa-vault"></i></div>
							<div class="summ-content">
								<h3>₹<%= totalPendingPayout.toLocaleString('en-IN') %>
								</h3>
								<span>Pending Obligations</span>
							</div>
						</div>
						<div class="summary-card-v">
							<div class="summ-icon" style="color: #2ecc71;"><i class="fas fa-hand-holding-dollar"></i>
							</div>
							<div class="summ-content">
								<h3>₹<%= totalPaidOut.toLocaleString('en-IN') %>
								</h3>
								<span>Total Disbursed</span>
							</div>
						</div>
					</div>

					<% if (providers.length===0) { %>
						<div class="text-center py-5"
							style="background: rgba(255,255,255,0.02); border-radius: 30px; border: 2px dashed #333;">
							<i class="fas fa-users mb-4" style="font-size: 4rem; color: #444;"></i>
							<h3 class="text-muted">No Workforce found</h3>
							<p class="text-muted">Active service providers will appear here for payroll management.</p>
						</div>
						<% } else { %>
							<div class="remuneration-grid">
								<% providers.forEach(provider=> { %>
									<div class="payroll-card">
										<div class="payroll-header">
											<div class="provider-identity">
												<div class="avatar-payroll">
													<%= provider.firstName.charAt(0) %>
												</div>
												<div>
													<h6>
														<%= provider.firstName %>
															<%= provider.lastName %>
													</h6>
													<span class="role-tag-v">
														<%= provider.role==='mechanic' ? 'Certified Mechanic'
															: 'Fuel Logistics Op' %>
													</span>
												</div>
											</div>
											<div class="text-end">
												<div class="small fw-bold text-success">
													<%= provider.commissionRate || 40 %>% Share
												</div>
											</div>
										</div>

										<div class="payroll-body">
											<div class="wallet-stat-grid">
												<div class="wallet-field">
													<label>Gross Earnings</label>
													<span>₹<%= (provider.totalEarnings || 0).toLocaleString('en-IN') %>
															</span>
												</div>
												<div class="wallet-field"
													style="background: #fff8e1; border-color: #ffe082;">
													<label>Pending Payout</label>
													<span class="text-warning">₹<%= (provider.pendingEarnings ||
															0).toLocaleString('en-IN') %></span>
												</div>
											</div>

											<div class="small text-muted mb-0">
												<i class="fas fa-shield-halved me-2"></i> Documented Verification ID: #
												<%= provider._id.toString().slice(-6) %>
											</div>
										</div>

										<div class="payroll-footer">
											<div class="last-settlement">
												Last Payout: <%= provider.lastPaidAt ? new
													Date(provider.lastPaidAt).toLocaleDateString('en-IN') : 'Never' %>
											</div>
											<form action="/admin/payout/<%= provider._id %>" method="POST">
												<input type="hidden" name="amount"
													value="<%= provider.pendingEarnings || 0 %>">
												<button type="submit" class="payout-btn-v" <%=(provider.pendingEarnings
													|| 0) <=0 ? 'disabled' : '' %>>
													Settle Fund
												</button>
											</form>
										</div>
									</div>
									<% }) %>
							</div>
							<% } %>
			</div>

			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>