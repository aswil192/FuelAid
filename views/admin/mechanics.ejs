<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Mechanics Directory | RoadAid Admin</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.page-header {
			margin-bottom: 3rem;
			border-left: 5px solid var(--accent-yellow);
			padding-left: 1.5rem;
			display: flex;
			justify-content: space-between;
			align-items: center;
		}

		.page-header h2 {
			font-weight: 800;
			margin: 0;
			text-transform: uppercase;
			letter-spacing: 1px;
		}

		.count-badge-hero {
			background: #111;
			padding: 0.5rem 1.5rem;
			border-radius: 50px;
			border: 1px solid #333;
			display: flex;
			align-items: center;
			gap: 1rem;
		}

		.count-badge-hero span:first-child {
			color: var(--accent-yellow);
			font-weight: 800;
			font-size: 1.25rem;
		}

		.count-badge-hero span:last-child {
			color: #888;
			font-size: 0.8rem;
			text-transform: uppercase;
			font-weight: 700;
		}

		.mechanic-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
			gap: 2rem;
		}

		.mechanic-card-premium {
			background: var(--card-bg);
			border-radius: 25px;
			overflow: hidden;
			color: var(--text-dark);
			border: 1px solid #333;
			transition: var(--transition);
			display: flex;
			flex-direction: column;
		}

		.mechanic-card-premium:hover {
			transform: translateY(-5px);
			box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
		}

		.card-visual-header {
			height: 40px;
			background: #111;
			position: relative;
		}

		.verified-stamp {
			position: absolute;
			top: 15px;
			right: 15px;
			background: var(--accent-yellow);
			color: #000;
			padding: 0.25rem 0.75rem;
			border-radius: 50px;
			font-size: 0.65rem;
			font-weight: 800;
			text-transform: uppercase;
		}

		.mechanic-profile-overlap {
			padding: 0 2rem;
			margin-top: -20px;
			margin-bottom: 1.5rem;
			display: flex;
			align-items: flex-end;
			gap: 1rem;
		}

		.mechanic-avatar-box {
			width: 70px;
			height: 70px;
			background: #fff;
			border-radius: 15px;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 1.5rem;
			font-weight: 800;
			color: #111;
			box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
			border: 4px solid var(--card-bg);
		}

		.mechanic-meta h5 {
			margin: 0;
			font-weight: 800;
			color: #111;
			font-size: 1.1rem;
		}

		.mechanic-meta p {
			margin: 0;
			color: #777;
			font-size: 0.8rem;
			font-weight: 600;
		}

		.mechanic-body-details {
			padding: 0 2rem 2rem;
			flex-grow: 1;
		}

		.info-strip {
			display: flex;
			align-items: center;
			gap: 1rem;
			margin-bottom: 1rem;
		}

		.info-strip i {
			width: 30px;
			color: var(--accent-yellow);
			font-size: 1rem;
		}

		.info-strip span {
			font-size: 0.85rem;
			font-weight: 600;
			color: #333;
		}

		.mechanic-action-footer {
			padding: 1.5rem 2rem;
			background: #f8f9fa;
		}

		.btn-view-profile {
			display: block;
			width: 100%;
			padding: 0.9rem;
			background: #111;
			color: #fff;
			text-align: center;
			text-decoration: none;
			border-radius: 12px;
			font-weight: 700;
			font-size: 0.85rem;
			text-transform: uppercase;
			transition: var(--transition);
		}

		.btn-view-profile:hover {
			background: var(--accent-yellow);
			color: #000;
			transform: scale(1.02);
		}

		@media (max-width: 991px) {
			#main-wrapper {
				margin-left: 0;
				padding: 1.5rem;
			}
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
		<%- include('../partials/adminSidebar', { title: 'Mechanics Management' }) %>

			<div id="main-wrapper">
				<div class="page-header">
					<div>
						<h2>Verified <span>Mechanics</span></h2>
						<p class="text-muted mb-0">Manage and monitor your certified mechanical service network.</p>
					</div>
					<div class="count-badge-hero">
						<span>
							<%= mechanics.length %>
						</span>
						<span>Active Personnel</span>
					</div>
				</div>

				<%- include('../partials/alerts') %>

					<% if(mechanics.length===0) { %>
						<div class="text-center py-5"
							style="background: rgba(255,255,255,0.02); border-radius: 30px; border: 2px dashed #333;">
							<i class="fas fa-wrench mb-4" style="font-size: 4rem; color: #444;"></i>
							<h3 class="text-muted">No Mechanics Found</h3>
							<p class="text-muted">Once verified, expert mechanics will appear in this directory.</p>
						</div>
						<% } else { %>
							<div class="mechanic-grid">
								<% mechanics.forEach((mech, index)=> { %>
									<div class="mechanic-card-premium">
										<div class="card-visual-header">
											<span class="verified-stamp"><i
													class="fas fa-check-circle me-1"></i>Verified</span>
										</div>

										<div class="mechanic-profile-overlap">
											<div class="mechanic-avatar-box">
												<%= mech.firstName.charAt(0) %>
													<%= mech.lastName.charAt(0) %>
											</div>
											<div class="mechanic-meta">
												<h5>
													<%= mech.firstName %>
														<%= mech.lastName %>
												</h5>
												<p>Mechanic ID: #<%= mech._id.toString().slice(-6) %>
												</p>
											</div>
										</div>

										<div class="mechanic-body-details">
											<div class="info-strip">
												<i class="fas fa-envelope"></i>
												<span>
													<%= mech.email %>
												</span>
											</div>
											<div class="info-strip">
												<i class="fas fa-phone"></i>
												<span>
													<%= mech.phone || 'N/A' %>
												</span>
											</div>
											<div class="info-strip">
												<i class="fas fa-calendar-check"></i>
												<span>Joined: <%= mech.joinedTime.toLocaleDateString() %></span>
											</div>
										</div>

										<div class="mechanic-action-footer">
											<a href="/admin/mechanic/view/<%= mech._id %>" class="btn-view-profile">
												Full Profile Details <i class="fas fa-arrow-right ms-2"></i>
											</a>
										</div>
									</div>
									<% }) %>
							</div>
							<% } %>
			</div>

			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>