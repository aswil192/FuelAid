<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>User Verification | RoadAid Admin</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.page-header {
			margin-bottom: 3rem;
			border-left: 5px solid var(--accent-yellow);
			padding-left: 1.5rem;
		}

		.page-header h2 {
			font-weight: 800;
			margin: 0;
			text-transform: uppercase;
			letter-spacing: 1px;
		}

		.verification-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
			gap: 2rem;
		}

		.user-verify-card {
			background: var(--card-bg);
			border-radius: 25px;
			overflow: hidden;
			color: var(--text-dark);
			border: 1px solid #333;
			transition: var(--transition);
			display: flex;
			flex-direction: column;
		}

		.user-verify-card:hover {
			transform: translateY(-5px);
			box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
		}

		.card-accent-header {
			background: #111;
			padding: 1.5rem 2rem;
			display: flex;
			justify-content: space-between;
			align-items: center;
		}

		.role-badge {
			padding: 0.4rem 1rem;
			border-radius: 50px;
			font-size: 0.7rem;
			font-weight: 800;
			text-transform: uppercase;
			letter-spacing: 1px;
		}

		.role-mechanic {
			background: #e67e22;
			color: #fff;
		}

		.role-fuel {
			background: #27ae60;
			color: #fff;
		}

		.card-body-content {
			padding: 2rem;
			flex-grow: 1;
		}

		.user-primary-info {
			display: flex;
			align-items: center;
			gap: 1.5rem;
			margin-bottom: 2rem;
		}

		.user-initials-circle {
			width: 60px;
			height: 60px;
			background: #f0f0f0;
			border-radius: 50%;
			display: flex;
			align-items: center;
			justify-content: center;
			font-weight: 800;
			font-size: 1.25rem;
			color: #111;
			border: 2px solid var(--accent-yellow);
		}

		.user-meta-info h5 {
			margin: 0;
			font-weight: 800;
			color: #111;
		}

		.user-meta-info p {
			margin: 0;
			font-size: 0.85rem;
			color: #777;
			font-weight: 600;
		}

		.detail-row-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 1.5rem;
			margin-bottom: 2rem;
		}

		.detail-field {
			display: flex;
			flex-direction: column;
		}

		.detail-field label {
			font-size: 0.65rem;
			font-weight: 700;
			text-transform: uppercase;
			color: #999;
			margin-bottom: 0.25rem;
		}

		.detail-field span {
			font-size: 0.9rem;
			font-weight: 600;
			color: #111;
			word-break: break-all;
		}

		.action-footer {
			padding: 1.5rem 2rem;
			background: #f8f9fa;
			border-top: 1px solid #eee;
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 1rem;
		}

		.btn-verify {
			padding: 0.8rem;
			border-radius: 12px;
			font-weight: 800;
			text-transform: uppercase;
			font-size: 0.8rem;
			border: none;
			transition: var(--transition);
		}

		.btn-approve-v {
			background: #2ecc71;
			color: #fff;
		}

		.btn-approve-v:hover {
			background: #27ae60;
			transform: scale(1.02);
		}

		.btn-reject-v {
			background: #ff4444;
			color: #fff;
		}

		.btn-reject-v:hover {
			background: #cc0000;
			transform: scale(1.02);
		}

		.empty-verifications {
			text-align: center;
			padding: 5rem;
			background: rgba(255, 255, 255, 0.02);
			border-radius: 30px;
			border: 2px dashed #333;
		}

		.empty-verifications i {
			font-size: 4rem;
			color: #444;
			margin-bottom: 2rem;
		}

		@media (max-width: 991px) {
			#main-wrapper {
				margin-left: 0;
				padding: 1.5rem;
			}

			.verification-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
		<%- include('../partials/adminSidebar', { title: 'Verify Users' }) %>

			<div id="main-wrapper">
				<div class="page-header">
					<h2>User <span>Verification</span></h2>
					<p class="text-muted mb-0">Review and authorize new service provider registrations.</p>
				</div>

				<%- include('../partials/alerts') %>

					<div class="cards-container">
						<% const filteredUsers=pendingUsers.filter(u=> u.role !== 'admin'); %>

							<% if(filteredUsers.length===0) { %>
								<div class="empty-verifications">
									<i class="fas fa-user-check"></i>
									<h3 class="text-muted">No Pending Verifications</h3>
									<p class="text-muted">The system is fully caught up. All users are verified.</p>
								</div>
								<% } else { %>
									<div class="verification-grid">
										<% filteredUsers.forEach((user, index)=> { %>
											<div class="user-verify-card">
												<div class="card-accent-header">
													<i class="fas fa-shield-halved text-warning"></i>
													<span
														class="role-badge <%= user.role === 'mechanic' ? 'role-mechanic' : 'role-fuel' %>">
														<%= user.role==='fueldeliveryboy' ? 'Delivery Boy' : user.role
															%>
													</span>
												</div>

												<div class="card-body-content">
													<div class="user-primary-info">
														<div class="user-initials-circle">
															<%= user.firstName.charAt(0) %>
																<%= user.lastName.charAt(0) %>
														</div>
														<div class="user-meta-info">
															<h5>
																<%= user.firstName %>
																	<%= user.lastName %>
															</h5>
															<p>Registered on <%= new
																	Date(user.createdAt).toLocaleDateString() %>
															</p>
														</div>
													</div>

													<div class="detail-row-grid">
														<div class="detail-field">
															<label>Aadhaar Number</label>
															<span>
																<%= user.acn || 'Not Provided' %>
															</span>
														</div>
														<div class="detail-field">
															<label>License Number</label>
															<span>
																<%= user.dl || 'Not Provided' %>
															</span>
														</div>
														<div class="detail-field">
															<label>Email Address</label>
															<span>
																<%= user.email %>
															</span>
														</div>
														<div class="detail-field">
															<label>Phone Number</label>
															<span>
																<%= user.phone || 'N/A' %>
															</span>
														</div>
													</div>

													<div class="detail-field w-100">
														<label>Registered Address</label>
														<span>
															<%= user.address || 'N/A' %>
														</span>
													</div>
												</div>

												<div class="action-footer">
													<form action="/admin/verify-users/approve/<%= user._id %>"
														method="POST">
														<input type="hidden" name="type" value="<%= user.role %>">
														<button type="submit" class="btn-verify btn-approve-v w-100">
															<i class="fas fa-check-double me-2"></i> Approve
														</button>
													</form>
													<form action="/admin/verify-users/reject/<%= user._id %>"
														method="POST">
														<input type="hidden" name="type" value="<%= user.role %>">
														<button type="submit" class="btn-verify btn-reject-v w-100">
															<i class="fas fa-user-times me-2"></i> Reject
														</button>
													</form>
												</div>
											</div>
											<% }) %>
									</div>
									<% } %>
					</div>
			</div>

			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>