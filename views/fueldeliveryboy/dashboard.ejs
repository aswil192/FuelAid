<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Fuel Delivery Command Center | FuelAid</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.fuel-hero {
			background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.85)), url('/assets/images/fuel_custom_banner.png');
			background-size: cover;
			background-position: center;
			border-radius: 30px;
			padding: 4rem;
			margin-bottom: 3rem;
			border: 1px solid #333;
			position: relative;
			overflow: hidden;
			box-shadow: 0 20px 50px rgba(0,0,0,0.6);
		}

		.fuel-hero::after {
			content: '';
			position: absolute;
			top: -50%;
			right: -10%;
			width: 500px;
			height: 500px;
			background: radial-gradient(circle, rgba(247, 183, 29, 0.05) 0%, transparent 70%);
			z-index: 1;
		}

		.hero-content {
			position: relative;
			z-index: 2;
		}

		.hero-tag {
			background: rgba(247, 183, 29, 0.1);
			color: var(--accent-yellow);
			padding: 0.5rem 1.25rem;
			border-radius: 50px;
			font-size: 0.75rem;
			font-weight: 800;
			text-transform: uppercase;
			letter-spacing: 2px;
			display: inline-block;
			margin-bottom: 1.5rem;
			border: 1px solid rgba(247, 183, 29, 0.2);
		}

		.hero-title {
			font-weight: 800;
			font-size: 3.5rem;
			margin-bottom: 1.5rem;
			letter-spacing: -1px;
			color: #fff;
			text-shadow: 0 4px 15px rgba(0,0,0,0.3);
		}

		.hero-title span {
			color: var(--accent-yellow);
		}

		.hero-subtitle {
			font-size: 1.1rem;
			color: rgba(255,255,255,0.7);
			max-width: 600px;
			line-height: 1.7;
			margin-bottom: 2rem;
		}

		.live-clock-box {
			background: rgba(0, 0, 0, 0.4);
			backdrop-filter: blur(10px);
			border: 1px solid rgba(255,255,255,0.1);
			padding: 2rem;
			border-radius: 25px;
			text-align: right;
			box-shadow: 0 20px 40px rgba(0,0,0,0.3);
		}

		.clock-time {
			font-size: 3rem;
			font-weight: 800;
			color: var(--accent-yellow);
			line-height: 1;
			margin-bottom: 0.25rem;
		}

		.clock-date {
			font-size: 0.85rem;
			color: #666;
			text-transform: uppercase;
			font-weight: 700;
			letter-spacing: 1px;
		}

		.metrics-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
			gap: 1.5rem;
			margin-bottom: 4rem;
		}

		.metric-card-premium {
			background: var(--card-bg);
			border-radius: 25px;
			padding: 2rem;
			display: flex;
			flex-direction: column;
			gap: 1rem;
			transition: var(--transition);
			border: 1px solid #eee;
			color: var(--text-dark);
		}

		.metric-card-premium:hover {
			transform: translateY(-10px);
			box-shadow: 0 15px 40px rgba(0,0,0,0.1);
		}

		.metric-icon-box {
			width: 60px;
			height: 60px;
			border-radius: 18px;
			background: #f8f9fa;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 1.5rem;
			color: #111;
			margin-bottom: 0.5rem;
		}

		.metric-value {
			font-size: 2.5rem;
			font-weight: 800;
			line-height: 1;
		}

		.metric-label {
			font-size: 0.85rem;
			font-weight: 700;
			color: #888;
			text-transform: uppercase;
			letter-spacing: 1px;
		}

		.quick-action-tile {
			background: var(--card-bg);
			border-radius: 25px;
			padding: 2.5rem 2rem;
			text-align: center;
			transition: var(--transition);
			text-decoration: none;
			color: var(--text-dark);
			border: 1px solid #eee;
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 1.25rem;
		}

		.quick-action-tile:hover {
			background: var(--accent-yellow);
			color: #000;
			border-color: var(--accent-yellow);
			transform: scale(1.05);
		}

		.action-icon-circle {
			width: 80px;
			height: 80px;
			border-radius: 50%;
			background: #f8f9fa;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 2rem;
			transition: var(--transition);
		}

		.quick-action-tile:hover .action-icon-circle {
			background: rgba(0,0,0,0.1);
			color: #000;
		}

		.guideline-container {
			background: var(--card-bg);
			border-radius: 30px;
			padding: 4rem;
			border: 1px solid #eee;
			margin-bottom: 4rem;
			color: var(--text-dark);
		}

		.guideline-step {
			display: flex;
			gap: 2rem;
			margin-bottom: 2.5rem;
		}

		.step-num {
			width: 50px;
			height: 50px;
			background: #111;
			color: var(--accent-yellow);
			border-radius: 15px;
			display: flex;
			align-items: center;
			justify-content: center;
			font-weight: 800;
			flex-shrink: 0;
		}

		.step-info h5 {
			font-weight: 800;
			margin-bottom: 0.5rem;
		}

		.step-info p {
			color: #666;
			line-height: 1.6;
			margin: 0;
		}

		@media (max-width: 991px) {
			#main-wrapper {
				margin-left: 0;
				padding: 1.5rem;
			}
			.hero-title {
				font-size: 2.5rem;
			}
			.live-clock-box {
				text-align: left;
				margin-top: 2rem;
			}
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
	<%- include('../partials/fuelSidebar') %>

	<div id="main-wrapper">
		<%- include('../partials/alerts') %>

		<!-- Hero Section -->
		<div class="fuel-hero">
			<div class="row align-items-center hero-content">
				<div class="col-lg-8">
					<div class="hero-tag">Operational Status: Active</div>
					<h1 class="hero-title">Welcome Back, <span><%= fueldeliveryboy.firstName %>!</span></h1>
					<p class="hero-subtitle">You are a vital part of RoadAid's emergency network. Your swift fuel delivery keeps travelers moving and safe. Ready for the next delivery?</p>
					<div class="mt-4">
						<a href="/fueldeliveryboy/viewRequests" class="btn-yellow">Check Fuel Requests <i class="fas fa-gas-pump ms-2"></i></a>
					</div>
				</div>
				<div class="col-lg-4">
					<div class="live-clock-box">
						<div class="clock-time" id="clock">--:--</div>
						<div class="clock-date" id="currentDate">Loading...</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Performance Metrics -->
		<h2 class="section-title mb-4"><i class="fas fa-chart-line me-2"></i> Performance <span>Metrics</span></h2>
		<div class="metrics-grid">
			<div class="metric-card-premium">
				<div class="metric-icon-box" style="background: rgba(39, 174, 96, 0.1); color: #27ae60;">
					<i class="fas fa-check-circle"></i>
				</div>
				<div>
					<div class="metric-value"><%= typeof completedJobs !== 'undefined' ? completedJobs : 0 %></div>
					<div class="metric-label">Deliveries Completed</div>
				</div>
			</div>
			<div class="metric-card-premium">
				<div class="metric-icon-box" style="background: rgba(52, 152, 219, 0.1); color: #3498db;">
					<i class="fas fa-tasks"></i>
				</div>
				<div>
					<div class="metric-value"><%= typeof acceptedJobs !== 'undefined' ? acceptedJobs : 0 %></div>
					<div class="metric-label">Active Jobs</div>
				</div>
			</div>
			<div class="metric-card-premium">
				<div class="metric-icon-box" style="background: rgba(243, 156, 18, 0.1); color: #f39c12;">
					<i class="fas fa-star"></i>
				</div>
				<div>
					<div class="metric-value"><%= typeof rating !== 'undefined' ? rating.toFixed(1) : '5.0' %></div>
					<div class="metric-label">Your Rating</div>
				</div>
			</div>
			<div class="metric-card-premium">
				<div class="metric-icon-box" style="background: rgba(155, 89, 182, 0.1); color: #9b59b6;">
					<i class="fas fa-hourglass-half"></i>
				</div>
				<div>
					<div class="metric-value"><%= typeof pendingJobs !== 'undefined' ? pendingJobs : 0 %></div>
					<div class="metric-label">Pending Requests</div>
				</div>
			</div>
		</div>

		<!-- Quick Operations -->
		<h2 class="section-title mb-4"><i class="fas fa-bolt me-2"></i> Quick <span>Operations</span></h2>
		<div class="row g-4 mb-5">
			<div class="col-md-4">
				<a href="/fueldeliveryboy/viewRequests" class="quick-action-tile">
					<div class="action-icon-circle"><i class="fas fa-satellite-dish"></i></div>
					<h5 class="fw-bold mb-0">Find Requests</h5>
				</a>
			</div>
			<div class="col-md-4">
				<a href="/fueldeliveryboy/accepted" class="quick-action-tile">
					<div class="action-icon-circle"><i class="fas fa-map-marked-alt"></i></div>
					<h5 class="fw-bold mb-0">Active Tasks</h5>
				</a>
			</div>
			<div class="col-md-4">
				<a href="/fueldeliveryboy/profile" class="quick-action-tile">
					<div class="action-icon-circle"><i class="fas fa-user-cog"></i></div>
					<h5 class="fw-bold mb-0">Settings</h5>
				</a>
			</div>
		</div>

		<!-- Operational Guidelines -->
		<div class="guideline-container">
			<h2 class="section-title mb-5"><i class="fas fa-clipboard-list me-2"></i> Delivery <span>Guidelines</span></h2>
			<div class="row">
				<div class="col-md-6">
					<div class="guideline-step">
						<div class="step-num">01</div>
						<div class="step-info">
							<h5>Scan for Requests</h5>
							<p>Check "View Fuel Requests" to find assigned deliveries near your current location.</p>
						</div>
					</div>
					<div class="guideline-step">
						<div class="step-num">02</div>
						<div class="step-info">
							<h5>Accept & Navigate</h5>
							<p>Accept the job and use the customer's coordinates to navigate to the delivery site safely.</p>
						</div>
					</div>
				</div>
				<div class="col-md-6">
					<div class="guideline-step">
						<div class="step-num">03</div>
						<div class="step-info">
							<h5>Deliver Fuel</h5>
							<p>Perform the fuel delivery following all safety protocols. Ensure correct fuel type and quantity.</p>
						</div>
					</div>
					<div class="guideline-step">
						<div class="step-num">04</div>
						<div class="step-info">
							<h5>Confirm & Earning</h5>
							<p>Mark the delivery as complete. Your earnings will be updated instantly in your dashboard.</p>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Motivational Quote -->
		<div class="modern-card text-center p-5 mb-4" style="background: #111; color: white; border: 1px solid #333;">
			<i class="fas fa-quote-left mb-4" style="font-size: 2rem; color: var(--accent-yellow);"></i>
			<p class="fs-4 italic fw-light" style="letter-spacing: 0.5px;">"Service to others is the rent you pay for your room here on earth."</p>
			<div class="fw-bold text-uppercase mt-4" style="color: var(--accent-yellow); font-size: 0.8rem; letter-spacing: 2px;">— Muhammad Ali</div>
		</div>
	</div>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
	<script src="/assets/js/script.js"></script>
	<script src="/socket.io/socket.io.js"></script>

	<script>
		// Real-time Tactical Clock
		function updateClock() {
			const now = new Date();
			const time = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
			const date = now.toLocaleDateString(undefined, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
			const clockEl = document.getElementById('clock');
			const dateEl = document.getElementById('currentDate');
			if(clockEl) clockEl.textContent = time;
			if(dateEl) dateEl.textContent = date;
		}
		updateClock();
		setInterval(updateClock, 1000);

		// Socket Intelligence System
		const socket = io();
		const fuelId = "<%= fueldeliveryboy._id %>";
		let simulatedLat = 28.628151;
		let simulatedLng = 77.367783;

		function simulateLocation() {
			simulatedLat += 0.0001;
			simulatedLng += 0.0001;
			socket.emit('fuelLocationUpdate', {
				fuelId,
				lat: simulatedLat,
				lng: simulatedLng
			});
		}
		setInterval(simulateLocation, 5000);
	</script>
</body>
</html>
