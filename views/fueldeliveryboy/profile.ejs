<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Partner Profile | FuelAid</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.profile-hero {
			background: var(--card-bg);
			border-radius: 30px;
			padding: 4rem 2rem;
			text-align: center;
			margin-bottom: 3rem;
			position: relative;
			overflow: hidden;
			border: 1px solid #eee;
		}

		.profile-avatar-giant {
			width: 180px;
			height: 180px;
			border-radius: 50%;
			object-fit: cover;
			border: 8px solid #f8f9fa;
			box-shadow: 0 20px 40px rgba(0,0,0,0.1);
			margin-bottom: 1.5rem;
		}

		.avatar-edit-trigger {
			position: absolute;
			bottom: 15px;
			right: 50%;
			transform: translateX(80px);
			background: var(--accent-yellow);
			width: 45px;
			height: 45px;
			border-radius: 50%;
			display: flex;
			align-items: center;
			justify-content: center;
			color: #000;
			cursor: pointer;
			box-shadow: 0 5px 15px rgba(0,0,0,0.2);
			transition: var(--transition);
		}

		.avatar-edit-trigger:hover { transform: translateX(80px) scale(1.1); }

		.intel-section {
			background: #fff;
			border-radius: 25px;
			padding: 2.5rem;
			margin-bottom: 2rem;
			border: 1px solid #eee;
		}

		.intel-header {
			display: flex;
			align-items: center;
			gap: 1rem;
			margin-bottom: 2rem;
			border-bottom: 1px solid #f0f0f0;
			padding-bottom: 1rem;
		}

		.intel-header i {
			color: var(--accent-yellow);
			font-size: 1.5rem;
		}

		.intel-header h5 {
			margin: 0;
			font-weight: 800;
			color: #000;
			text-transform: uppercase;
			letter-spacing: 1px;
		}

		.form-floating > label { color: #888; font-weight: 600; }
		.form-control {
			border-radius: 12px;
			border: 1px solid #e0e0e0;
			font-weight: 600;
			padding: 1rem;
		}

		.gender-tactical {
			display: flex;
			gap: 1rem;
		}

		.gender-btn {
			flex: 1;
			padding: 1rem;
			border-radius: 15px;
			border: 2px solid #f0f0f0;
			text-align: center;
			cursor: pointer;
			transition: var(--transition);
			color: #888;
			font-weight: 700;
		}

		.gender-btn.active {
			border-color: var(--accent-yellow);
			background: rgba(247, 183, 29, 0.05);
			color: #000;
		}

		.gender-btn input { display: none; }

		@media (max-width: 991px) {
			#main-wrapper { margin-left: 0; padding: 1.5rem; }
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
	<%- include('../partials/fuelSidebar') %>

	<div id="main-wrapper">
		<%- include('../partials/alerts') %>

		<div class="mb-5">
			<h1 class="hero-title mb-0">Partner <span>Profile</span></h1>
			<p class="text-muted">Manage your tactical credentials and delivery logistics.</p>
		</div>

		<form action="/fueldeliveryboy/profile?_method=PUT" method="POST" enctype="multipart/form-data">
			<div class="profile-hero">
				<div class="position-relative d-inline-block">
					<img id="profilePreview" src="<%= currentUser.profilePic || '/assets/images/default-avatar.png' %>" class="profile-avatar-giant" alt="Partner Avatar">
					<label for="profilePic" class="avatar-edit-trigger">
						<i class="fas fa-camera"></i>
					</label>
					<input type="file" name="profilePic" id="profilePic" accept="image/*" class="d-none">
				</div>
				<h2 class="fw-800 mt-3 text-dark"><%= currentUser.firstName %> <%= currentUser.lastName %></h2>
				<p class="text-muted fw-600"><i class="fas fa-gas-pump me-2 text-warning"></i>Certified Fuel Delivery Partner</p>
			</div>

			<div class="row">
				<div class="col-lg-8">
					<div class="intel-section">
						<div class="intel-header">
							<i class="fas fa-user-shield"></i>
							<h5>Identity Intel</h5>
						</div>
						<div class="row g-4">
							<div class="col-md-6">
								<div class="form-floating">
									<input type="text" name="firstName" class="form-control" id="fName" value="<%= currentUser.firstName %>" required>
									<label for="fName">First Name</label>
								</div>
							</div>
							<div class="col-md-6">
								<div class="form-floating">
									<input type="text" name="lastName" class="form-control" id="lName" value="<%= currentUser.lastName %>" required>
									<label for="lName">Last Name</label>
								</div>
							</div>
							<div class="col-12">
								<div class="form-floating text-muted">
									<input type="email" class="form-control bg-light" id="email" value="<%= currentUser.email %>" disabled>
									<label for="email">Encrypted Comms ID (Email)</label>
								</div>
							</div>
							<div class="col-12">
								<label class="small fw-800 text-muted mb-2 text-uppercase">Partner Designation</label>
								<div class="gender-tactical">
									<label class="gender-btn <%= currentUser.gender === 'male' ? 'active' : '' %>">
										<input type="radio" name="gender" value="male" <%= currentUser.gender === 'male' ? 'checked' : '' %>>
										<i class="fas fa-mars me-2"></i> Male
									</label>
									<label class="gender-btn <%= currentUser.gender === 'female' ? 'active' : '' %>">
										<input type="radio" name="gender" value="female" <%= currentUser.gender === 'female' ? 'checked' : '' %>>
										<i class="fas fa-venus me-2"></i> Female
									</label>
								</div>
							</div>
						</div>
					</div>

					<div class="intel-section">
						<div class="intel-header">
							<i class="fas fa-satellite-dish"></i>
							<h5>Operational Contact</h5>
						</div>
						<div class="row g-4">
							<div class="col-12">
								<div class="form-floating">
									<input type="text" name="address" class="form-control" id="addr" value="<%= currentUser.address %>">
									<label for="addr">Base of Operations (Address)</label>
								</div>
							</div>
							<div class="col-12">
								<div class="form-floating">
									<input type="tel" name="phone" class="form-control" id="tel" value="<%= currentUser.phone %>">
									<label for="tel">Tactical Phone Line</label>
								</div>
							</div>
						</div>
					</div>
				</div>

				<div class="col-lg-4">
					<div class="intel-section">
						<div class="intel-header">
							<i class="fas fa-medal"></i>
							<h5>Field Experience</h5>
						</div>
						<div class="form-floating mb-4">
							<input type="number" name="experience" class="form-control" id="exp" value="<%= currentUser.experience || '' %>">
							<label for="exp">Service Years</label>
						</div>
						<div class="form-floating">
							<input type="text" name="availability" class="form-control" id="avail" value="<%= currentUser.availability || '' %>">
							<label for="avail">Duty Cycles (Availability)</label>
						</div>
					</div>

					<div class="intel-section">
						<div class="intel-header">
							<i class="fas fa-truck"></i>
							<h5>Logistics Info</h5>
						</div>
						<div class="form-floating mb-4">
							<input type="text" name="licensePlate" class="form-control" id="plate" value="<%= currentUser.licensePlate || '' %>">
							<label for="plate">Unit Registration (License #)</label>
						</div>
						<div class="form-floating">
							<input type="text" name="vehicleModel" class="form-control" id="model" value="<%= currentUser.vehicleModel || '' %>">
							<label for="model">Unit Model</label>
						</div>
					</div>

					<button type="submit" class="btn-yellow w-100 py-4 fw-800 text-uppercase letter-spacing-1">
						<i class="fas fa-sync-alt me-2"></i> Save Profile Data
					</button>
				</div>
			</div>
		</form>
	</div>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
	<script src="/assets/js/script.js"></script>
	<script>
		// Image Sync Logic
		const fileInput = document.getElementById('profilePic');
		const previewImg = document.getElementById('profilePreview');

		if (fileInput && previewImg) {
			fileInput.addEventListener('change', function () {
				const file = this.files[0];
				if (file && file.type.startsWith('image/')) {
					const reader = new FileReader();
					reader.onload = function (e) {
						const imageData = e.target.result;
						previewImg.src = imageData;
						// Store in localStorage for header sync
						localStorage.setItem('profilePhotoPreview', imageData);
					};
					reader.readAsDataURL(file);
				}
			});
		}

		// Tactical Gender Toggle
		document.querySelectorAll('.gender-btn').forEach(btn => {
			btn.addEventListener('click', function() {
				document.querySelectorAll('.gender-btn').forEach(b => b.classList.remove('active'));
				this.classList.add('active');
			});
		});

		// Form submission handler to sync header
		const form = document.querySelector('form');
		if (form) {
			form.addEventListener('submit', function() {
				// Clear the localStorage preview when actually submitting
				localStorage.removeItem('profilePhotoPreview');
			});
		}

		// Check for any stored preview on page load
		window.addEventListener('load', function() {
			if (previewImg) {
				const storedPreview = localStorage.getItem('profilePhotoPreview');
				if (storedPreview) {
					previewImg.src = storedPreview;
				}
			}
		});
	</script>
</body>
</html>
