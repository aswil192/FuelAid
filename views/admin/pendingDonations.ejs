<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Pending Deliveries | RoadAid Admin</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.page-header {
			margin-bottom: 3rem;
			border-left: 5px solid var(--accent-yellow);
			padding-left: 1.5rem;
		}

		.page-header h2 {
			font-weight: 800;
			margin: 0;
			text-transform: uppercase;
			letter-spacing: 1px;
		}

		.pending-grid {
			display: grid;
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.pending-job-card {
			background: var(--card-bg);
			border-radius: 25px;
			overflow: hidden;
			color: var(--text-dark);
			border: 1px solid #333;
			box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
			display: grid;
			grid-template-columns: 350px 1fr;
		}

		/* Left side: Job Summary */
		.job-summary-side {
			background: #111;
			padding: 2.5rem;
			color: #fff;
			display: flex;
			flex-direction: column;
			gap: 1.5rem;
		}

		.job-id-tag {
			font-size: 0.75rem;
			font-weight: 800;
			color: var(--accent-yellow);
			text-transform: uppercase;
			letter-spacing: 1px;
		}

		.customer-mini-profile {
			display: flex;
			align-items: center;
			gap: 1rem;
		}

		.customer-avatar-v {
			width: 50px;
			height: 50px;
			background: var(--accent-yellow);
			color: #000;
			border-radius: 50%;
			display: flex;
			align-items: center;
			justify-content: center;
			font-weight: 800;
			font-size: 1.1rem;
		}

		.job-type-pill {
			display: inline-block;
			background: #222;
			color: var(--accent-yellow);
			padding: 0.4rem 1rem;
			border-radius: 50px;
			font-weight: 800;
			font-size: 0.7rem;
			text-transform: uppercase;
			border: 1px solid #333;
		}

		/* Right side: Action Area */
		.job-action-side {
			padding: 2.5rem;
			display: flex;
			flex-direction: column;
		}

		.job-details-row {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 2rem;
			margin-bottom: 2rem;
		}

		.detail-item-box label {
			display: block;
			font-size: 0.7rem;
			text-transform: uppercase;
			color: #999;
			font-weight: 700;
			margin-bottom: 0.5rem;
		}

		.detail-item-box span {
			font-weight: 700;
			color: #111;
			font-size: 0.95rem;
		}

		.dispatch-section {
			background: #f8f9fa;
			border: 1px solid #eee;
			border-radius: 20px;
			padding: 1.5rem;
			margin-top: auto;
		}

		.dispatch-header {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			margin-bottom: 1rem;
			color: #111;
			font-weight: 800;
			font-size: 0.9rem;
			text-transform: uppercase;
		}

		.dispatch-form {
			display: grid;
			grid-template-columns: 1fr auto;
			gap: 1rem;
		}

		.select-provider {
			background: #fff;
			border: 2px solid #eee;
			border-radius: 12px;
			padding: 0.75rem 1rem;
			font-weight: 600;
			color: #333;
		}

		.select-provider:focus {
			border-color: var(--accent-yellow);
			outline: none;
		}

		.btn-dispatch {
			background: var(--accent-yellow);
			color: #000;
			border: none;
			padding: 0 2rem;
			border-radius: 12px;
			font-weight: 800;
			text-transform: uppercase;
			font-size: 0.8rem;
			transition: var(--transition);
		}

		.btn-dispatch:hover {
			transform: scale(1.05);
			box-shadow: 0 5px 15px rgba(247, 183, 29, 0.3);
		}

		.view-details-link {
			display: inline-block;
			margin-top: 1.5rem;
			color: #888;
			font-weight: 700;
			font-size: 0.8rem;
			text-decoration: none;
			transition: var(--transition);
		}

		.view-details-link:hover {
			color: #111;
			padding-left: 5px;
		}

		@media (max-width: 991px) {
			#main-wrapper {
				margin-left: 0;
				padding: 1.5rem;
			}

			.pending-job-card {
				grid-template-columns: 1fr;
			}

			.job-summary-side {
				padding: 1.5rem;
			}

			.job-action-side {
				padding: 1.5rem;
			}
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
		<%- include('../partials/adminSidebar', { title: 'Pending Deliveries' }) %>

			<div id="main-wrapper">
				<div class="page-header">
					<h2>Pending <span>Deliveries</span></h2>
					<p class="text-muted mb-0">High-priority service requests awaiting provider assignment.</p>
				</div>

				<%- include('../partials/alerts') %>

					<% if(pendingDonations.length===0) { %>
						<div class="text-center py-5"
							style="background: rgba(255,255,255,0.02); border-radius: 30px; border: 2px dashed #333;">
							<i class="fas fa-check-circle mb-4" style="font-size: 4rem; color: #444;"></i>
							<h3 class="text-muted">Queue is Empty</h3>
							<p class="text-muted">No pending deliveries found. All systems operational.</p>
						</div>
						<% } else { %>
							<div class="pending-grid">
								<% pendingDonations.forEach((job, index)=> { %>
									<div class="pending-job-card">
										<!-- Left Summary -->
										<div class="job-summary-side">
											<span class="job-id-tag">Request ID: #<%= job._id.toString().slice(-6) %>
													</span>

											<div class="customer-mini-profile">
												<div class="customer-avatar-v">
													<%= job.customer.firstName.charAt(0) %>
												</div>
												<div>
													<div class="fw-bold">
														<%= job.customer.firstName %>
															<%= job.customer.lastName %>
													</div>
													<div class="small text-muted">Premium Customer</div>
												</div>
											</div>

											<div class="mt-4">
												<div class="job-type-pill mb-2">
													<%= job.serviceCategory %>
												</div>
												<div class="small" style="color: #aaa;">
													<i class="fas fa-calendar-alt me-2 text-warning"></i>
													<%= new Date(job.createdAt).toLocaleString([], { dateStyle: 'medium'
														, timeStyle: 'short' }) %>
												</div>
											</div>

											<a href="/admin/donation/view/<%= job._id %>" class="view-details-link">
												FULL LOGS <i class="fas fa-arrow-right ms-2 mt-1"></i>
											</a>
										</div>

										<!-- Right Action side -->
										<div class="job-action-side">
											<div class="job-details-row">
												<div class="detail-item-box">
													<label>Services Requested</label>
													<span>
														<%= job.subServices || 'Standard Assistance' %>
													</span>
												</div>
												<div class="detail-item-box">
													<label>Distance / ETA</label>
													<span class="text-warning">Calculating...</span>
												</div>
												<div class="detail-item-box" style="grid-column: span 2;">
													<label>Pickup / Delivery Point</label>
													<span class="text-truncate d-block"><i
															class="fas fa-map-marker-alt me-2 text-danger"></i>
														<%= job.address || 'Location Hidden' %>
													</span>
												</div>
											</div>

											<div class="dispatch-section">
												<div class="dispatch-header">
													<i class="fas fa-satellite-dish"></i>
													Manual Dispatch
												</div>
												<form action="/admin/donation/assign/<%= job._id %>" method="POST"
													class="dispatch-form">
													<select name="mechanic" class="select-provider" required>
														<option disabled selected value="">Pick Available Provider
														</option>
														<% mechanics.forEach(function(mech) { %>
															<option value="<%= mech._id %>">
																<%= mech.firstName %>
																	<%= mech.lastName %> (Verified)
															</option>
															<% }); %>
													</select>
													<button type="submit" class="btn-dispatch">
														Assign Now
													</button>
												</form>
											</div>
										</div>
									</div>
									<% }) %>
							</div>
							<% } %>
			</div>

			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>