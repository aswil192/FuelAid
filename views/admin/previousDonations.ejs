<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Job History Archive | RoadAid Admin</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.page-header {
			margin-bottom: 3rem;
			border-left: 5px solid var(--accent-yellow);
			padding-left: 1.5rem;
			display: flex;
			justify-content: space-between;
			align-items: center;
		}

		.page-header h2 {
			font-weight: 800;
			margin: 0;
			text-transform: uppercase;
			letter-spacing: 1px;
		}

		.archive-stats {
			background: #111;
			padding: 0.5rem 1.5rem;
			border-radius: 50px;
			border: 1px solid #333;
			display: flex;
			align-items: center;
			gap: 1rem;
		}

		.archive-stats span:first-child {
			color: #2ecc71;
			font-weight: 800;
			font-size: 1.25rem;
		}

		.archive-stats span:last-child {
			color: #888;
			font-size: 0.8rem;
			text-transform: uppercase;
			font-weight: 700;
		}

		.history-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
			gap: 2rem;
		}

		.history-card-premium {
			background: var(--card-bg);
			border-radius: 25px;
			overflow: hidden;
			color: var(--text-dark);
			border: 1px solid #333;
			transition: var(--transition);
			display: flex;
			flex-direction: column;
			position: relative;
		}

		.history-card-premium:hover {
			transform: translateY(-5px);
			box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
		}

		.completed-timestamp {
			position: absolute;
			top: 20px;
			right: 20px;
			font-size: 0.65rem;
			font-weight: 700;
			text-transform: uppercase;
			color: #999;
			background: #f0f0f0;
			padding: 0.3rem 0.8rem;
			border-radius: 50px;
		}

		.card-inner-padding {
			padding: 2rem;
			padding-top: 3rem;
			flex-grow: 1;
		}

		.customer-history-block {
			display: flex;
			align-items: center;
			gap: 1.25rem;
			margin-bottom: 2rem;
		}

		.hist-avatar-box {
			width: 55px;
			height: 55px;
			background: #111;
			color: var(--accent-yellow);
			border-radius: 15px;
			display: flex;
			align-items: center;
			justify-content: center;
			font-weight: 800;
			font-size: 1.25rem;
		}

		.hist-meta h5 {
			margin: 0;
			font-weight: 800;
			color: #111;
			font-size: 1.1rem;
		}

		.category-pill-v {
			display: inline-block;
			background: #e9ecef;
			color: #555;
			padding: 0.2rem 0.75rem;
			border-radius: 50px;
			font-size: 0.65rem;
			font-weight: 800;
			text-transform: uppercase;
			margin-top: 0.25rem;
		}

		.history-details-list {
			display: flex;
			flex-direction: column;
			gap: 1.25rem;
		}

		.hist-row {
			display: flex;
			align-items: flex-start;
			gap: 1rem;
		}

		.hist-row i {
			width: 20px;
			color: #888;
			font-size: 0.9rem;
			margin-top: 3px;
		}

		.hist-row div {
			flex: 1;
		}

		.hist-row label {
			display: block;
			font-size: 0.6rem;
			text-transform: uppercase;
			font-weight: 700;
			color: #999;
			margin-bottom: 0.1rem;
		}

		.hist-row span {
			font-size: 0.85rem;
			font-weight: 600;
			color: #333;
			line-height: 1.4;
			display: block;
		}

		.history-action-btm {
			padding: 1.5rem 2rem;
			background: #f8f9fa;
			border-top: 1px solid #eee;
		}

		.btn-archive-view {
			display: block;
			width: 100%;
			padding: 0.8rem;
			background: #fff;
			color: #111;
			text-align: center;
			text-decoration: none;
			border-radius: 12px;
			font-weight: 800;
			font-size: 0.75rem;
			text-transform: uppercase;
			border: 2px solid #eee;
			transition: var(--transition);
		}

		.btn-archive-view:hover {
			background: #111;
			color: #fff;
			border-color: #111;
		}

		@media (max-width: 991px) {
			#main-wrapper {
				margin-left: 0;
				padding: 1.5rem;
			}
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
		<%- include('../partials/adminSidebar', { title: 'Previous Deliveries' }) %>

			<div id="main-wrapper">
				<div class="page-header">
					<div>
						<h2>History <span>Archive</span></h2>
						<p class="text-muted mb-0">Record of all successfully completed service requests.</p>
					</div>
					<div class="archive-stats">
						<span>
							<%= previousDonations.length %>
						</span>
						<span>Fulfilled Jobs</span>
					</div>
				</div>

				<%- include('../partials/alerts') %>

					<% if(previousDonations.length===0) { %>
						<div class="text-center py-5"
							style="background: rgba(255,255,255,0.02); border-radius: 30px; border: 2px dashed #333;">
							<i class="fas fa-archive mb-4" style="font-size: 4rem; color: #444;"></i>
							<h3 class="text-muted">Archive is Empty</h3>
							<p class="text-muted">Completed delivery records will appear here.</p>
						</div>
						<% } else { %>
							<div class="history-grid">
								<% previousDonations.forEach((job, index)=> { %>
									<div class="history-card-premium">
										<div class="completed-timestamp">
											<%= new Date(job.createdAt).toLocaleDateString([], { month: 'short' ,
												day: 'numeric' , year: 'numeric' }) %>
										</div>

										<div class="card-inner-padding">
											<div class="customer-history-block">
												<div class="hist-avatar-box">
													<%= (job.customer?.firstName || 'U' ).charAt(0) %>
												</div>
												<div class="hist-meta">
													<h5>
														<%= (job.customer?.firstName || 'Unknown' ) %>
															<%= (job.customer?.lastName || 'User' ) %>
													</h5>
													<span class="category-pill-v">
														<%= job.serviceCategory %>
													</span>
												</div>
											</div>

											<div class="history-details-list">
												<div class="hist-row">
													<i class="fas fa-layer-group"></i>
													<div>
														<label>Services</label>
														<span>
															<%= job.subServices || 'Standard Assistance' %>
														</span>
													</div>
												</div>
												<div class="hist-row">
													<i class="fas fa-map-marker-alt"></i>
													<div>
														<label>Final Landmark</label>
														<span class="text-truncate" style="max-width: 250px;">
															<%= job.address || 'N/A' %>
														</span>
													</div>
												</div>
												<div class="hist-row">
													<i class="fas fa-check-circle text-success"></i>
													<div>
														<label>Status</label>
														<span class="text-success fw-bold">SUCCESSFULLY COMPLETED</span>
													</div>
												</div>
											</div>
										</div>

										<div class="history-action-btm">
											<a href="/admin/donation/view/<%= job._id %>" class="btn-archive-view">
												View Full Audit Log
											</a>
										</div>
									</div>
									<% }) %>
							</div>
							<% } %>
			</div>

			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>