<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Personal Identity | RoadAid Admin</title>

	<!-- Fonts -->
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

	<!-- CSS -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
	<link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

	<style>
		body {
			background-color: var(--primary-bg);
			color: var(--text-light);
			font-family: var(--font-main);
		}

		#main-wrapper {
			margin-left: 280px;
			padding: 2.5rem;
			min-height: 100vh;
		}

		.page-header {
			margin-bottom: 3rem;
			border-left: 5px solid var(--accent-yellow);
			padding-left: 1.5rem;
		}

		.page-header h2 {
			font-weight: 800;
			margin: 0;
			text-transform: uppercase;
			letter-spacing: 1px;
		}

		.profile-settings-card {
			background: var(--card-bg);
			border-radius: 40px;
			overflow: hidden;
			border: 1px solid #333;
			color: var(--text-dark);
			max-width: 900px;
			margin: 0 auto;
		}

		.settings-hero {
			background: #111;
			padding: 4rem 3rem;
			display: flex;
			align-items: center;
			gap: 2.5rem;
			border-bottom: 1px solid #333;
		}

		.admin-avatar-v {
			width: 100px;
			height: 100px;
			background: var(--accent-yellow);
			border-radius: 30px;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 2.5rem;
			color: #111;
			box-shadow: 0 10px 30px rgba(247, 183, 29, 0.2);
		}

		.admin-meta-v h3 {
			margin: 0;
			font-weight: 800;
			color: #fff;
			font-size: 1.75rem;
		}

		.admin-meta-v span {
			font-size: 0.75rem;
			text-transform: uppercase;
			font-weight: 800;
			color: var(--accent-yellow);
			letter-spacing: 2px;
		}

		.settings-body {
			padding: 3.5rem;
		}

		.form-section-v {
			margin-bottom: 3.5rem;
		}

		.form-section-v:last-child {
			margin-bottom: 0;
		}

		.section-label {
			font-size: 0.8rem;
			font-weight: 800;
			text-transform: uppercase;
			color: #111;
			letter-spacing: 1.5px;
			margin-bottom: 1.5rem;
			display: flex;
			align-items: center;
			gap: 1rem;
		}

		.section-label::after {
			content: "";
			flex: 1;
			height: 1px;
			background: #eee;
		}

		.input-group-v {
			margin-bottom: 2rem;
		}

		.input-group-v label {
			display: block;
			font-size: 0.65rem;
			text-transform: uppercase;
			font-weight: 700;
			color: #999;
			margin-bottom: 0.5rem;
		}

		.control-v {
			width: 100%;
			background: #fcfcfc;
			border: 2px solid #eee;
			border-radius: 12px;
			padding: 0.8rem 1.25rem;
			font-weight: 600;
			color: #111;
			transition: var(--transition);
		}

		.control-v:focus {
			border-color: var(--accent-yellow);
			outline: none;
			background: #fff;
		}

		.control-v:disabled {
			background: #f0f0f0;
			opacity: 0.7;
		}

		/* Modern Radio Buttons */
		.gender-selector-v {
			display: flex;
			gap: 1.5rem;
		}

		.gender-option-v {
			flex: 1;
			position: relative;
		}

		.gender-option-v input {
			position: absolute;
			opacity: 0;
			width: 100%;
			height: 100%;
			cursor: pointer;
			z-index: 2;
		}

		.gender-card-v {
			padding: 1rem;
			border: 2px solid #eee;
			border-radius: 15px;
			text-align: center;
			font-weight: 800;
			font-size: 0.8rem;
			text-transform: uppercase;
			color: #999;
			transition: var(--transition);
		}

		.gender-option-v input:checked+.gender-card-v {
			background: #111;
			border-color: #111;
			color: var(--accent-yellow);
		}

		.save-action-v {
			margin-top: 4rem;
		}

		.btn-update-v {
			width: 100%;
			background: #111;
			color: #fff;
			border: none;
			padding: 1.25rem;
			border-radius: 15px;
			font-weight: 800;
			text-transform: uppercase;
			letter-spacing: 1px;
			font-size: 0.85rem;
			transition: var(--transition);
		}

		.btn-update-v:hover {
			background: var(--accent-yellow);
			color: #000;
			transform: scale(1.02);
			box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
		}

		@media (max-width: 991px) {
			#main-wrapper {
				margin-left: 0;
				padding: 1.5rem;
			}

			.settings-hero {
				padding: 2.5rem 1.5rem;
				flex-direction: column;
				text-align: center;
			}

			.settings-body {
				padding: 2rem 1.5rem;
			}
		}
	</style>
</head>

<body class="dashboard-body">
	<%- include('../partials/header') %>
		<%- include('../partials/adminSidebar', { title: 'Admin Settings' }) %>

			<div id="main-wrapper">
				<div class="page-header">
					<h2>System <span>Identity</span></h2>
					<p class="text-muted mb-0">Manage your administrative credentials and personal preferences.</p>
				</div>

				<%- include('../partials/alerts') %>

					<div class="profile-settings-card">
						<div class="settings-hero">
							<div class="admin-avatar-v">
								<i class="fas fa-shield-halved"></i>
							</div>
							<div class="admin-meta-v">
								<span>Authorized Personnel</span>
								<h3>
									<%= currentUser.firstName %>
										<%= currentUser.lastName %>
								</h3>
							</div>
						</div>

						<div class="settings-body">
							<form action="/admin/profile?_method=PUT" method="POST">
								<div class="form-section-v">
									<div class="section-label">Personnel Details</div>
									<div class="row">
										<div class="col-md-6">
											<div class="input-group-v">
												<label>Forename</label>
												<input type="text" name="admin[firstName]" class="control-v"
													value="<%= currentUser.firstName %>" required>
											</div>
										</div>
										<div class="col-md-6">
											<div class="input-group-v">
												<label>Surname</label>
												<input type="text" name="admin[lastName]" class="control-v"
													value="<%= currentUser.lastName %>" required>
											</div>
										</div>
									</div>
									<div class="input-group-v">
										<label>System Auth Email</label>
										<input type="email" class="control-v" value="<%= currentUser.email %>" disabled>
									</div>
									<div class="input-group-v">
										<label>Biological Identity</label>
										<div class="gender-selector-v">
											<div class="gender-option-v">
												<input type="radio" name="admin[gender]" value="male" <%
													if(currentUser.gender=='male' ){%> checked <%}%>>
													<div class="gender-card-v">Male Identification</div>
											</div>
											<div class="gender-option-v">
												<input type="radio" name="admin[gender]" value="female" <%
													if(currentUser.gender=='female' ){%> checked <%}%>>
													<div class="gender-card-v">Female Identification</div>
											</div>
										</div>
									</div>
								</div>

								<div class="form-section-v">
									<div class="section-label">Operational Contact</div>
									<div class="input-group-v">
										<label>Registered HQ Address</label>
										<input type="text" name="admin[address]" class="control-v"
											placeholder="Define primary operations address.."
											value="<%= currentUser.address %>">
									</div>
									<div class="input-group-v">
										<label>Verified Hotlink Number</label>
										<input type="number" name="admin[phone]" class="control-v"
											placeholder="Reference contact number.." value="<%= currentUser.phone %>">
									</div>
								</div>

								<div class="save-action-v">
									<button type="submit" class="btn-update-v">
										Commit Identity Changes
									</button>
								</div>
							</form>
						</div>
					</div>
			</div>

			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>