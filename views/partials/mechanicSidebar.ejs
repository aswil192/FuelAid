<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>
<body>
	<style>
		:root {
			--primary-bg: #000000;
			--accent-yellow: #F7B71D;
			--text-light: #FFFFFF;
			--sidebar-width: 280px;
			--transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		}

		#sidebar {
			width: var(--sidebar-width);
			height: 100vh;
			position: fixed;
			left: 0;
			top: 0;
			background: var(--primary-bg);
			border-right: 1px solid #222;
			padding: 2rem 1.5rem;
			display: flex;
			flex-direction: column;
			z-index: 1010;
			overflow-y: auto;
			scrollbar-width: none;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
		}

		#sidebar::-webkit-scrollbar {
			display: none;
		}

		.sidebar-brand {
			display: flex;
			align-items: center;
			gap: 1rem;
			padding: 0 0.5rem 2.5rem;
			border-bottom: 1px solid #222;
			margin-bottom: 2rem;
		}

		.sidebar-brand img {
			height: 40px;
		}

		.sidebar-brand span {
			color: var(--text-light);
			font-size: 1.25rem;
			font-weight: 800;
			letter-spacing: 1px;
			text-transform: uppercase;
		}

		.sidebar-brand span b {
			color: var(--accent-yellow);
		}

		.nav-section-label {
			color: #555;
			font-size: 0.7rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 1.5px;
			padding: 0.5rem 1rem 0.75rem;
			display: block;
		}

		#sidebar-nav {
			list-style: none;
			padding: 0;
			margin: 0;
			display: flex;
			flex-direction: column;
			gap: 0.5rem;
		}

		#sidebar-nav li a {
			color: #888;
			text-decoration: none;
			display: flex;
			align-items: center;
			gap: 1rem;
			padding: 0.9rem 1.25rem;
			border-radius: 12px;
			font-weight: 600;
			font-size: 0.9rem;
			transition: var(--transition);
		}

		#sidebar-nav li a i {
			font-size: 1.1rem;
			width: 20px;
			text-align: center;
		}

		#sidebar-nav li a:hover {
			color: var(--text-light);
			background: #111;
			transform: translateX(5px);
		}

		#sidebar-nav li a.active {
			color: #000;
			background: var(--accent-yellow);
			box-shadow: 0 10px 20px rgba(247, 183, 29, 0.2);
		}

		.nav-user-info {
			margin-bottom: 2rem;
			padding: 1rem;
			background: #111;
			border-radius: 15px;
			display: flex;
			align-items: center;
			gap: 1rem;
			border: 1px solid #222;
            position: relative;
		}

		.user-avatar-small {
			width: 40px;
			height: 40px;
			border-radius: 50%;
			background: var(--accent-yellow);
			color: #000;
			display: flex;
			align-items: center;
			justify-content: center;
			font-weight: 800;
			border: 2px solid #333;
		}

		.user-meta-small {
			display: flex;
			flex-direction: column;
			line-height: 1.2;
		}

		.user-meta-small span:first-child {
			color: var(--text-light);
			font-size: 0.85rem;
			font-weight: 700;
		}

		.user-meta-small span:last-child {
			color: var(--accent-yellow);
			font-size: 0.7rem;
			font-weight: 600;
			text-transform: uppercase;
		}

		.logout-btn-container {
			margin-top: auto;
			padding-top: 2rem;
		}

		.logout-btn-nav {
			color: #ff4444 !important;
		}

		.logout-btn-nav:hover {
			background: rgba(255, 68, 68, 0.1) !important;
		}

		@media (max-width: 991px) {
			#sidebar {
				transform: translateX(-100%);
			}
			#sidebar.active {
				transform: translateX(0);
			}
		}
	</style>

	<div id="sidebar">
		<!-- Sidebar Toggle (Inside Menu) -->
		<button id="sidebarClose" class="sidebar-close-btn" title="Hide Menu">
			<i class="fas fa-chevron-left"></i>
		</button>

		<div class="sidebar-brand">
			<img src="/assets/images/FUEL AID_logo.png" alt="Logo">
			<span>Road<b>Aid</b></span>
		</div>

		<div class="nav-user-info">
			<div class="user-avatar-small">
				<%= currentUser.firstName.charAt(0).toUpperCase() %>
			</div>
			<div class="user-meta-small">
				<span>
					<%= currentUser.firstName %> <%= currentUser.lastName %>
				</span>
				<span>Partner Mechanic</span>
			</div>
		</div>

		<span class="nav-section-label">Main Menu</span>
		<ul id="sidebar-nav">
			<li>
				<a href="/mechanic/dashboard" class="<%= typeof title != 'undefined' && title === 'Dashboard' ? 'active' : '' %>">
					<i class="fas fa-th-large"></i> Dashboard
				</a>
			</li>
			<li>
				<a href="/mechanic/viewRequests" class="<%= typeof title != 'undefined' && title === 'View Service Requests' ? 'active' : '' %>">
					<i class="fas fa-search-location"></i> Available Jobs
				</a>
			</li>
		</ul>

		<span class="nav-section-label mt-4">Operations</span>
		<ul id="sidebar-nav">
			<li>
				<a href="/mechanic/accepted" class="<%= typeof title != 'undefined' && title === 'Accepted Requests' ? 'active' : '' %>">
					<i class="fas fa-clipboard-check"></i> Accepted Jobs
				</a>
			</li>
			<li>
				<a href="/mechanic/completed" class="<%= typeof title != 'undefined' && title === 'Completed Services' ? 'active' : '' %>">
					<i class="fas fa-history"></i> Work History
				</a>
			</li>
		</ul>

		<span class="nav-section-label mt-4">Account</span>
		<ul id="sidebar-nav">
			<li>
				<a href="/mechanic/earnings" class="<%= typeof title != 'undefined' && title === 'My Earnings' ? 'active' : '' %>">
					<i class="fas fa-wallet"></i> My Earnings
				</a>
			</li>
			<li>
				<a href="/mechanic/profile" class="<%= typeof title != 'undefined' && title === 'My Profile' ? 'active' : '' %>">
					<i class="fas fa-user-circle"></i> Profile Settings
				</a>
			</li>
		</ul>

		<div class="logout-btn-container">
			<ul id="sidebar-nav">
				<li>
					<a href="/auth/logout" class="logout-btn-nav">
						<i class="fas fa-sign-out-alt"></i> Logout
					</a>
				</li>
			</ul>
		</div>
	</div>

	<!-- Floating Open Handle (Visible when hidden) -->
	<button id="sidebarOpen" class="sidebar-open-btn" title="Open Menu">
		<i class="fas fa-chevron-right"></i>
	</button>
</body>
</html>