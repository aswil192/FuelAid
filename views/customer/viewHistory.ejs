<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Service History | FuelAid</title>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

  <!-- CSS -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
  <link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

  <style>
    body {
      background-color: var(--primary-bg);
      color: var(--text-light);
      font-family: var(--font-main);
    }

    #main-wrapper {
      margin-left: 280px;
      padding: 2.5rem;
      min-height: 100vh;
    }

    .page-header {
      margin-bottom: 3rem;
      border-left: 5px solid var(--accent-yellow);
      padding-left: 1.5rem;
    }

    .page-header h2 {
      font-weight: 800;
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .history-card {
      background: var(--card-bg);
      border-radius: var(--border-radius);
      padding: 2rem;
      margin-bottom: 2rem;
      color: var(--text-dark);
      border: 1px solid #333;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
      transition: var(--transition);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 100%;
    }

    .history-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
    }

    .history-card h5 {
      font-weight: 700;
      color: #111;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .history-card h5 i {
      color: var(--accent-yellow);
    }

    .history-detail-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
      margin-bottom: 1.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid #eee;
    }

    .detail-item label {
      display: block;
      font-size: 0.7rem;
      text-transform: uppercase;
      font-weight: 700;
      color: #999;
      margin-bottom: 0.2rem;
    }

    .detail-item span {
      font-weight: 600;
      font-size: 0.9rem;
      color: #444;
    }

    .sub-services-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }

    .sub-badge {
      background: #f0f0f0;
      padding: 0.2rem 0.8rem;
      border-radius: 50px;
      font-size: 0.75rem;
      font-weight: 600;
      color: #666;
    }

    .price-badge {
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--accent-yellow);
      text-align: right;
    }

    .receipt-btn {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      text-decoration: none;
      background: #f8f9fa;
      border: 1px solid #eee;
      color: #444;
      padding: 0.8rem;
      border-radius: 10px;
      font-weight: 700;
      transition: var(--transition);
    }

    .receipt-btn:hover {
      background: var(--accent-yellow);
      color: #000;
      border-color: var(--accent-yellow);
    }

    @media (max-width: 991px) {
      #main-wrapper {
        margin-left: 0;
        padding: 1.5rem;
      }
    }
  </style>
</head>

<body class="dashboard-body">
  <%- include('../partials/header') %>
    <%- include('../partials/customerSidebar', { title: 'Service History' }) %>

      <div id="main-wrapper">
        <div class="page-header">
          <h2>Service <span>History</span></h2>
          <p class="text-muted mb-0">A detailed record of all your completed journeys with us.</p>
        </div>

        <% if (services.length===0 || !services.some(s=> s.status === 'completed')) { %>
          <div class="empty-state text-center py-5"
            style="background: rgba(255,255,255,0.02); border-radius: 20px; border: 2px dashed #333;">
            <i class="fas fa-folder-open mb-4" style="font-size: 4rem; color: #444;"></i>
            <h3 class="text-muted">No completed services yet</h3>
            <p class="text-muted">Your service history will appear here once you've completed a request.</p>
            <a href="/customer/request-service" class="btn-yellow mt-3">Start a New Journey</a>
          </div>
          <% } else { %>
            <div class="row g-4">
              <% services.forEach((service)=> { %>
                <% if (service.status=='completed' ) { %>
                  <div class="col-lg-6 col-xl-4">
                    <div class="history-card">
                      <div>
                        <h5>
                          <i class="fas <%= service.serviceCategory === 'fuel' ? 'fa-gas-pump' : 'fa-tools' %>"></i>
                          <%= service.serviceCategory.toUpperCase() %> SERVICE
                        </h5>

                        <div class="history-detail-grid">
                          <div class="detail-item">
                            <label>Requested On</label>
                            <span>
                              <%= new Date(service.createdAt).toLocaleDateString('en-IN', { day: '2-digit' ,
                                month: 'short' , year: 'numeric' }) %>
                            </span>
                          </div>
                          <div class="detail-item">
                            <label>Completed On</label>
                            <span>
                              <%= new Date(service.completedAt).toLocaleDateString('en-IN', { day: '2-digit' ,
                                month: 'short' , year: 'numeric' }) %>
                            </span>
                          </div>
                          <div class="detail-item">
                            <label>Provider</label>
                            <span>
                              <% if (service.mechanic) { %>
                                <i class="fas fa-user-wrench me-1 text-muted"></i>
                                <%= service.mechanic.firstName %>
                                  <% } else if (service.fueldeliveryboy) { %>
                                    <i class="fas fa-motorcycle me-1 text-muted"></i>
                                    <%= service.fueldeliveryboy.firstName %>
                                      <% } else { %>
                                        N/A
                                        <% } %>
                            </span>
                          </div>
                          <div class="detail-item text-end">
                            <label>Total Paid</label>
                            <span class="price-badge">₹<%= service.baseAmount %></span>
                          </div>
                        </div>

                        <div class="mb-4">
                          <label class="small text-muted fw-bold text-uppercase mb-2 d-block">Services Rendered</label>
                          <div class="sub-services-badges">
                            <% service.subServices.forEach(sub=> { %>
                              <span class="sub-badge">
                                <%= sub %>
                              </span>
                              <% }) %>
                          </div>
                        </div>
                      </div>

                      <a href="/customer/receipt/<%= service._id %>" class="receipt-btn">
                        <i class="fas fa-file-pdf"></i> Download Receipt
                      </a>
                    </div>
                  </div>
                  <% } %>
                    <% }) %>
            </div>
            <% } %>
      </div>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>