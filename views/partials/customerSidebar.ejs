<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- <title>Document</title> -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css"
        integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
</head>

<body>
    <style>
        :root {
            --sidebar-bg: #111111;
            --sidebar-accent: #F7B71D;
            --sidebar-text: #b0b0b0;
            --sidebar-hover-bg: rgba(247, 183, 29, 0.1);
        }

        #sidebar {
            width: 280px;
            background-color: var(--sidebar-bg);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            padding: 2rem 1.5rem;
            border-right: 1px solid #222;
            z-index: 1010;
            transition: all 0.3s ease;
        }

        .sidebar-header {
            padding-bottom: 2rem;
            border-bottom: 1px solid #222;
            margin-bottom: 2rem;
        }

        .sidebar-header h4 {
            color: white;
            font-weight: 700;
            font-size: 1.2rem;
            margin: 0;
        }

        .sidebar-header span {
            color: var(--sidebar-accent);
        }

        #sidebar-nav {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .nav-item-sidebar {
            text-decoration: none;
        }

        .nav-link-sidebar {
            display: flex;
            align-items: center;
            padding: 0.8rem 1.2rem;
            color: var(--sidebar-text);
            border-radius: 12px;
            font-weight: 500;
            transition: all 0.3s ease;
            text-decoration: none;
            font-size: 0.95rem;
        }

        .nav-link-sidebar i {
            margin-right: 1rem;
            font-size: 1.1rem;
            width: 20px;
            text-align: center;
        }

        .nav-link-sidebar:hover {
            background-color: var(--sidebar-hover-bg);
            color: var(--sidebar-accent);
            transform: translateX(5px);
        }

        .nav-link-sidebar.active {
            background-color: var(--sidebar-accent);
            color: #000;
            box-shadow: 0 4px 15px rgba(247, 183, 29, 0.3);
        }

        .nav-link-sidebar.active i {
            color: #000;
        }

        /* Mobile trigger if needed later */
        @media (max-width: 991px) {
            #sidebar {
                transform: translateX(-100%);
            }

            #sidebar.active {
                transform: translateX(0);
            }
        }
    </style>

    <div id="sidebar">
        <!-- Sidebar Toggle (Inside Menu) -->
        <button id="sidebarClose" class="sidebar-close-btn" title="Hide Menu">
            <i class="fas fa-chevron-left"></i>
        </button>

        <div class="sidebar-header">
            <h4>Welcome, <span>
                    <%= currentUser.firstName %>
                </span></h4>
        </div>

        <ul id="sidebar-nav">
            <li>
                <a href="/customer/dashboard"
                    class="nav-link-sidebar <%= typeof title !== 'undefined' && title === 'Dashboard' ? 'active' : '' %>">
                    <i class="fas fa-th-large"></i> Dashboard
                </a>
            </li>
            <li>
                <a href="/customer/request-service"
                    class="nav-link-sidebar <%= typeof title !== 'undefined' && title === 'Request Service' ? 'active' : '' %>">
                    <i class="fas fa-tools"></i> Request Service
                </a>
            </li>
            <li>
                <a href="/customer/services/requested"
                    class="nav-link-sidebar <%= typeof title !== 'undefined' && title === 'Pending Requests' ? 'active' : '' %>">
                    <i class="fas fa-clock"></i> Pending Requests
                </a>
            </li>
            <li>
                <a href="/customer/viewHistory"
                    class="nav-link-sidebar <%= typeof title !== 'undefined' && title === 'Service History' ? 'active' : '' %>">
                    <i class="fas fa-history"></i> Service History
                </a>
            </li>
            <li>
                <a href="/customer/profile"
                    class="nav-link-sidebar <%= typeof title !== 'undefined' && title === 'My Profile' ? 'active' : '' %>">
                    <i class="fas fa-user"></i> My Profile
                </a>
            </li>
            <li class="mt-4">
                <a href="/auth/logout" class="nav-link-sidebar text-danger">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </li>
        </ul>
    </div>

    <!-- Floating Open Handle (Visible when hidden) -->
    <button id="sidebarOpen" class="sidebar-open-btn" title="Open Menu">
        <i class="fas fa-chevron-right"></i>
    </button>

</body>

</html>