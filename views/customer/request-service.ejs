<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Request Service | FuelAid</title>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700,800&display=swap" rel="stylesheet">

  <!-- CSS -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/assets/css/dashboard-redesign.css">
  <link rel="icon" type="image/png" href="/assets/images/FUEL AID_logo.png">

  <style>
    body {
      background-color: var(--primary-bg);
      color: var(--text-light);
      font-family: var(--font-main);
    }

    #main-wrapper {
      margin-left: 280px;
      padding: 2rem;
      min-height: 100vh;
    }

    .request-container {
      max-width: 900px;
      margin: 0 auto;
    }

    .form-card {
      background: var(--card-bg);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
      color: var(--text-dark);
    }

    .form-header {
      background: var(--accent-yellow);
      padding: 2.5rem;
      color: var(--text-dark);
      text-align: center;
    }

    .form-header h2 {
      font-weight: 800;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .form-header p {
      opacity: 0.8;
      font-weight: 500;
    }

    .form-body {
      padding: 3rem;
    }

    .service-selection-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-bottom: 2.5rem;
    }

    .service-opt {
      border: 2px solid #eee;
      border-radius: 15px;
      padding: 1.5rem;
      text-align: center;
      cursor: pointer;
      transition: var(--transition);
    }

    .service-opt i {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      color: #888;
      transition: var(--transition);
    }

    .service-opt span {
      display: block;
      font-weight: 700;
      color: #444;
    }

    .service-opt:hover {
      border-color: var(--accent-yellow);
      background: #fffdf5;
    }

    .service-opt.selected {
      border-color: var(--accent-yellow);
      background: #fffdf5;
      box-shadow: 0 10px 20px rgba(247, 183, 29, 0.1);
    }

    .service-opt.selected i {
      color: var(--accent-yellow);
      transform: scale(1.1);
    }

    .sub-service-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-top: 1rem;
    }

    .sub-opt {
      padding: 1rem;
      border: 1px solid #eee;
      border-radius: 10px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 1rem;
      transition: var(--transition);
    }

    .sub-opt:hover {
      background: #f8f9fa;
    }

    .sub-opt.selected {
      border-color: var(--accent-yellow);
      background: #fffdf5;
      font-weight: 600;
    }

    .sub-opt .badge {
      margin-left: auto;
    }

    .price-summary-box {
      background: #fcfcfc;
      border: 1px solid #eee;
      border-radius: 15px;
      padding: 1.5rem;
      margin: 2rem 0;
    }

    .price-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 0.5rem;
      color: #666;
    }

    .price-row.total {
      border-top: 2px solid #eee;
      margin-top: 1rem;
      padding-top: 1rem;
      color: var(--text-dark);
      font-weight: 800;
      font-size: 1.25rem;
    }

    /* Autocomplete Styling */
    .autocomplete-container {
      position: relative;
    }

    .autocomplete-dropdown {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: #fff;
      border-radius: 0 0 15px 15px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      z-index: 1000;
      max-height: 300px;
      overflow-y: auto;
      border: 1px solid #eee;
      display: none;
    }

    .autocomplete-item {
      padding: 1rem;
      cursor: pointer;
      border-bottom: 1px solid #f1f1f1;
      transition: var(--transition);
    }

    .autocomplete-item:hover {
      background: #f8f9fa;
      padding-left: 1.5rem;
    }

    .autocomplete-item:last-child {
      border-bottom: none;
    }

    .form-label {
      font-weight: 700;
      margin-bottom: 0.75rem;
      color: #333;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .form-control {
      padding: 0.8rem 1.2rem;
      border-radius: 10px;
      border: 2px solid #eee;
      font-family: inherit;
    }

    .form-control:focus {
      border-color: var(--accent-yellow);
      box-shadow: none;
    }

    .file-upload-zone {
      border: 2px dashed #eee;
      border-radius: 15px;
      padding: 2rem;
      text-align: center;
      cursor: pointer;
      transition: var(--transition);
    }

    .file-upload-zone:hover {
      border-color: var(--accent-yellow);
      background: #fffdf5;
    }

    @media (max-width: 991px) {
      #main-wrapper {
        margin-left: 0;
        padding: 1rem;
      }
    }
  </style>
</head>

<body class="dashboard-body">
  <%- include('../partials/header') %>
    <%- include('../partials/customerSidebar', { title: 'Request Service' }) %>

      <div id="main-wrapper">
        <div class="request-container">
          <div class="form-card">
            <div class="form-header">
              <h2><i class="fas fa-tools me-2"></i>Request Service</h2>
              <p>Tell us what you need, and we'll dispatch help immediately.</p>
            </div>

            <form action="/customer/request-service" method="POST" enctype="multipart/form-data" class="form-body">
              <%- include('../partials/alerts') %>

                <!-- Step 1: Category -->
                <div class="mb-5">
                  <label class="form-label">Select Service Type</label>
                  <div class="service-selection-grid">
                    <div class="service-opt" data-category="roadside">
                      <i class="fas fa-car-side"></i>
                      <span>Roadside Assistance</span>
                    </div>
                    <div class="service-opt" data-category="fuel">
                      <i class="fas fa-gas-pump"></i>
                      <span>Fuel Services</span>
                    </div>
                  </div>
                  <input type="hidden" name="request[serviceCategory]" id="serviceCategory" required>
                </div>

                <!-- Step 2: Sub-services -->
                <div id="subServiceSection" class="mb-5" style="display: none;">
                  <label class="form-label">Specific Assistance Needed</label>
                  <div class="sub-service-grid" id="subServiceGrid"></div>
                </div>

                <!-- Fuel Quantity (Conditional) -->
                <div id="fuelQuantitySection" class="mb-5" style="display: none;">
                  <label class="form-label">Fuel Quantity (Liters)</label>
                  <input type="number" name="request[quantity]" class="form-control" placeholder="e.g. 5" min="1">
                </div>

                <!-- Step 3: Location -->
                <div class="mb-5 autocomplete-container">
                  <label class="form-label">Service Location</label>
                  <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i
                        class="fas fa-map-marker-alt text-danger"></i></span>
                    <input type="text" name="request[address]" id="addressInput" class="form-control border-start-0"
                      placeholder="Start typing your location..." required autocomplete="off">
                  </div>
                  <div id="autocompleteDropdown" class="autocomplete-dropdown"></div>
                </div>

                <!-- Distance & Charges Info -->
                <div id="distanceInfo" class="price-summary-box" style="display: none;">
                  <div class="price-row">
                    <span>Base Service Charges</span>
                    <span>₹<span id="baseChargeSummary">0</span></span>
                  </div>
                  <div class="price-row">
                    <span>Travel Charges (₹12/km)</span>
                    <span>₹<span id="travelChargeSummary">0</span></span>
                  </div>
                  <div class="price-row">
                    <span>Estimated Distance</span>
                    <span><span id="distanceValue">0</span> km</span>
                  </div>
                  <div class="price-row total">
                    <span>Total Estimated Amount</span>
                    <span>₹<span id="totalAmountSummary">0</span></span>
                  </div>
                  <small class="text-muted mt-2 d-block">* Final amount may vary based on actual on-site work.</small>
                </div>

                <div class="row">
                  <div class="col-md-6 mb-4">
                    <label class="form-label">Contact Number</label>
                    <div class="input-group">
                      <span class="input-group-text bg-white">+91</span>
                      <input type="text" name="request[phone]" id="phoneInput" class="form-control"
                        placeholder="10-digit number" maxlength="10" required>
                    </div>
                  </div>
                  <div class="col-md-6 mb-4">
                    <label class="form-label">Vehicle Photo (Optional)</label>
                    <div class="file-upload-zone" id="dropZone">
                      <i class="fas fa-camera text-muted mb-2"></i>
                      <p class="small mb-0" id="fileName">Tap to upload / take photo</p>
                      <input type="file" name="vehiclePhotoPath" id="fileInput" class="d-none" accept="image/*">
                    </div>
                  </div>
                </div>

                <div class="mb-5">
                  <label class="form-label">Special Instructions</label>
                  <textarea name="request[customerToMechanicMsg]" class="form-control" rows="3"
                    placeholder="Describe the problem or give helpful landmarks..."></textarea>
                </div>

                <!-- Step 4: Payment -->
                <div id="paymentSection" style="display: none;">
                  <label class="form-label">Payment Mode</label>
                  <div class="row g-3 mb-5">
                    <div class="col-6">
                      <input type="radio" name="request[paymentMethod]" value="cash" id="payCash" class="btn-check"
                        checked>
                      <label class="btn btn-outline-secondary w-100 py-3 rounded-3" for="payCash">
                        <i class="fas fa-money-bill-wave d-block mb-2"></i> Cash
                      </label>
                    </div>
                    <div class="col-6">
                      <input type="radio" name="request[paymentMethod]" value="online" id="payOnline" class="btn-check">
                      <label class="btn btn-outline-secondary w-100 py-3 rounded-3" for="payOnline">
                        <i class="fas fa-globe d-block mb-2"></i> Online
                      </label>
                    </div>
                  </div>

                  <div class="form-check mb-5">
                    <input class="form-check-input" type="checkbox" id="termsCheck" required>
                    <label class="form-check-label small text-muted" for="termsCheck">
                      I confirm the details provided are accurate and agree to pay the calculated charges upon service
                      completion.
                    </label>
                  </div>

                  <input type="hidden" name="request[subServices]" id="subServiceInput">
                  <input type="hidden" name="request[travelCharges]" id="travelChargesInput" value="0">
                  <input type="hidden" name="request[totalAmount]" id="totalAmountInput" value="0">

                  <button type="submit" class="btn-yellow w-100 py-3" id="submitBtn">
                    Submit Request & Disptach Help <i class="fas fa-paper-plane ms-2"></i>
                  </button>
                </div>
            </form>
          </div>
        </div>
      </div>

      <!-- Scripts -->
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
      <script>
        const serviceOptions = {
          roadside: [
            { name: "Battery Jump Start", icon: "fa-battery-full", price: 1000 },
            { name: "Flat Tyre Repair", icon: "fa-tire", price: 2700 },
            { name: "Lockout Assistance", icon: "fa-key", price: 1250 },
            { name: "Minor Repairs", icon: "fa-tools", price: 800 },
            { name: "Towing Services", icon: "fa-truck", price: 4200 },
            { name: "Vehicle Custody", icon: "fa-shield-alt", price: 1700 }
          ],
          fuel: [
            { name: "Fuel Delivery - 500ml", icon: "fa-gas-pump", price: 75 },
            { name: "Fuel Delivery - 1L", icon: "fa-gas-pump", price: 120 },
            { name: "Fuel Tank Cleaning", icon: "fa-filter", price: 600 },
            { name: "Fuel Quality Testing", icon: "fa-flask", price: 350 },
            { name: "Premium Quality - 2.5L", icon: "fa-bolt", price: 270 },
            { name: "Eco-Friendly Fuel - 1L", icon: "fa-leaf", price: 130 }
          ]
        };

        const KMMC_LOCATION = { lat: 10.0168, lng: 76.2832 };
        const TRAVEL_CHARGE_PER_KM = 12;
        let selectedCategory = '';
        const selectedServices = new Set();
        let selectedLocation = null;

        // Category Selection
        document.querySelectorAll('.service-opt').forEach(opt => {
          opt.addEventListener('click', function () {
            document.querySelectorAll('.service-opt').forEach(o => o.classList.remove('selected'));
            this.classList.add('selected');
            selectedCategory = this.dataset.category;
            document.getElementById('serviceCategory').value = selectedCategory;

            renderSubServices(selectedCategory);
          });
        });

        function renderSubServices(category) {
          const grid = document.getElementById('subServiceGrid');
          const section = document.getElementById('subServiceSection');
          grid.innerHTML = '';
          selectedServices.clear();

          serviceOptions[category].forEach(service => {
            const item = document.createElement('div');
            item.className = 'sub-opt';
            item.dataset.name = service.name;
            item.dataset.price = service.price;
            item.innerHTML = `
                    <i class="fas ${service.icon}"></i>
                    <span>${service.name}</span>
                    <span class="badge bg-light text-dark">₹${service.price}</span>
                `;

            item.addEventListener('click', () => toggleService(item));
            grid.appendChild(item);
          });

          section.style.display = 'block';
          updateUI();
        }

        function toggleService(element) {
          const name = element.dataset.name;
          if (selectedServices.has(name)) {
            selectedServices.delete(name);
            element.classList.remove('selected');
          } else {
            selectedServices.add(name);
            element.classList.add('selected');
          }
          updateUI();
        }

        function updateUI() {
          const hasServices = selectedServices.size > 0;
          const subServiceInput = document.getElementById('subServiceInput');
          const fuelSection = document.getElementById('fuelQuantitySection');
          const paymentSection = document.getElementById('paymentSection');

          subServiceInput.value = Array.from(selectedServices).join(',');

          // Show fuel quantity if any delivery is selected
          let isDelivery = false;
          selectedServices.forEach(s => { if (s.includes('Delivery')) isDelivery = true; });
          fuelSection.style.display = isDelivery ? 'block' : 'none';

          paymentSection.style.display = hasServices ? 'block' : 'none';

          calculateTotals();
        }

        function calculateTotals() {
          let baseTotal = 0;
          selectedServices.forEach(name => {
            const all = [...serviceOptions.roadside, ...serviceOptions.fuel];
            const found = all.find(s => s.name === name);
            if (found) baseTotal += found.price;
          });

          const distanceInfo = document.getElementById('distanceInfo');
          if (baseTotal > 0) {
            distanceInfo.style.display = 'block';
            document.getElementById('baseChargeSummary').textContent = baseTotal;

            let travelCharge = 0;
            if (selectedLocation) {
              const dist = haversineDistance(selectedLocation.lat, selectedLocation.lng, KMMC_LOCATION.lat, KMMC_LOCATION.lng);
              travelCharge = Math.round(dist * TRAVEL_CHARGE_PER_KM);
              document.getElementById('distanceValue').textContent = dist.toFixed(2);
              document.getElementById('travelChargeSummary').textContent = travelCharge;
            }

            const total = baseTotal + travelCharge;
            document.getElementById('totalAmountSummary').textContent = total;
            document.getElementById('travelChargesInput').value = travelCharge;
            document.getElementById('totalAmountInput').value = total;
          } else {
            distanceInfo.style.display = 'none';
          }
        }

        // Location Autocomplete
        const addressInput = document.getElementById('addressInput');
        const dropdown = document.getElementById('autocompleteDropdown');
        let timeout;

        addressInput.addEventListener('input', function () {
          const q = this.value.trim();
          clearTimeout(timeout);
          if (q.length < 3) { dropdown.style.display = 'none'; return; }

          timeout = setTimeout(() => {
            fetch(`/api/autocomplete-locations?q=${encodeURIComponent(q)}`)
              .then(r => r.json())
              .then(data => {
                dropdown.innerHTML = '';
                if (data.results?.length) {
                  data.results.forEach(res => {
                    const div = document.createElement('div');
                    div.className = 'autocomplete-item';
                    div.innerHTML = `<strong>${res.name}</strong><br><small class="text-muted">${res.formatted}</small>`;
                    div.addEventListener('click', () => {
                      addressInput.value = res.formatted;
                      selectedLocation = { lat: res.lat, lng: res.lng };
                      dropdown.style.display = 'none';
                      calculateTotals();
                    });
                    dropdown.appendChild(div);
                  });
                  dropdown.style.display = 'block';
                }
              });
          }, 300);
        });

        function haversineDistance(lat1, lon1, lat2, lon2) {
          const R = 6371;
          const dLat = (lat2 - lat1) * Math.PI / 180;
          const dLon = (lon2 - lon1) * Math.PI / 180;
          const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
            Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
            Math.sin(dLon / 2) * Math.sin(dLon / 2);
          return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        }

        // File Input
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        dropZone.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', () => {
          if (fileInput.files.length) {
            document.getElementById('fileName').textContent = fileInput.files[0].name;
            dropZone.classList.add('bg-light');
          }
        });

        // Phone Validation
        document.getElementById('phoneInput').addEventListener('input', function () {
          this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);
        });
      </script>
</body>

</html>